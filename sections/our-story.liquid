<section class="our-story section-{{ section.id }}">
  <div class="page-width">
    <h1 class="our-story__heading">
      {{ section.settings.heading }}
    </h1>

    <div class="our-story__top-text">
      {{ section.settings.top_text }}
    </div>

    <div class="our-story__grid">
      <!-- IMAGE -->
      <div class="our-story__image">
        {% if section.settings.story_image %}
          {{
            section.settings.story_image
            | image_url: width: 1200
            | image_tag: loading: 'lazy', sizes: '(max-width: 768px) 100vw, 50vw'
          }}
        {% endif %}
      </div>

      <!-- CONTENT -->
      <div class="our-story__content">
        <h2>{{ section.settings.right_heading_1 }}</h2>
        <p>{{ section.settings.right_text_1 }}</p>

        <h2>{{ section.settings.right_heading_2 }}</h2>
        <p>{{ section.settings.right_text_2 }}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    padding: 60px 0;
  }

  .our-story__heading {
    text-align: center;
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .our-story__top-text {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 40px;
    color: #555;
    font-size: 15px;
    line-height: 1.6;
  }

  .our-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .our-story__image {
    border-radius: 16px;
    overflow: hidden;
  }

  .our-story__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .our-story__content h2 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .our-story__content p {
    font-size: 14px;
    color: #555;
    margin-bottom: 20px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .our-story__grid {
      grid-template-columns: 1fr;
    }

    .our-story__heading {
      font-size: 26px;
    }
  }
</style>
{% schema %}
{
  "name": "Our Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "top_text",
      "label": "Top Text"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Image"
    },
    {
      "type": "text",
      "id": "right_heading_1",
      "label": "Right Heading 1"
    },
    {
      "type": "textarea",
      "id": "right_text_1",
      "label": "Right Text 1"
    },
    {
      "type": "text",
      "id": "right_heading_2",
      "label": "Right Heading 2"
    },
    {
      "type": "textarea",
      "id": "right_text_2",
      "label": "Right Text 2"
    }
  ],
  "presets": [
    {
      "name": "Our Story"
    }
  ]
}
{% endschema %}
