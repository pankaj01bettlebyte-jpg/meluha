{{ 'category-tabs-products.css' | asset_url | stylesheet_tag }}

<div id="category-products" class="products-grid">
  {% for product in collection.products limit: 8 %}
    <div
      class="product-card"
      data-product-id="{{ product.id }}"
      data-variant-id="{{ product.variants.first.id }}"
      data-handle="{{ product.handle }}"
    >
      <button class="wishlist-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 21C12 21 3 14.5 3 8.5A5.5 5.5 0 0 1 12 5.17 5.5 5.5 0 0 1 21 8.5C21 14.5 12 21 12 21Z"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <a href="{{ product.url }}">
        <img src="{{ product.featured_image | image_url: width: 420 }}" width="420" height="320">
        <h4>{{ product.title | truncate: 40 }}</h4>
      </a>

      <div class="rating">⭐ 4.5</div>

      <p class="price">
        {{ product.price | money }}
        <span>each</span>
      </p>

      <div class="qty">
        <button data-action="decrease">-</button>
        <span class="qty-value">1</span>
        <button data-action="increase">+</button>
      </div>

      <button class="order-btn">Order Now</button>
    </div>
  {% endfor %}
</div>
