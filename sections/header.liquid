{{ 'header.css' | asset_url | stylesheet_tag }}

<style id="header-critical-css">
  /* Desktop defaults — applied immediately, no flash */
  .header__hamburger {
    display: none !important;
  }
  .header__nav {
    display: flex !important;
  }
  .header__icon-btn--search {
    display: flex !important;
  }
  .header__icon-btn--wishlist {
    display: flex !important;
  }
  /* Mobile overrides — also applied immediately */
  @media (max-width: 900px) {
    .header__hamburger {
      display: flex !important;
    }
    .header__nav {
      display: none !important;
    }
    .header__icon-btn--search {
      display: none !important;
    }
    .header__icon-btn--wishlist {
      display: none !important;
    }
  }
</style>

{%- liquid
  assign logo_image = section.settings.logo
  assign brand_name = section.settings.brand_name | default: shop.name
  assign logo_width = section.settings.logo_width | default: 80
  assign sticky = section.settings.sticky_header
  assign menu_handle = section.settings.menu | default: 'main-menu'
  assign menu = linklists[menu_handle]
-%}

<header
  class="site-header{% if sticky %} site-header--sticky{% endif %}"
  role="banner"
  data-header
>
  <div class="header__inner">
    {%- comment -%} ── LOGO / BRAND NAME ─────────────────────────────────── {%- endcomment -%}
    {%- comment -%}
      Priority order:
        1. shop.brand.logo  — set in Shopify Admin → Brand Assets (recommended)
        2. section.settings.logo — legacy image_picker setting
        3. brand_name text fallback — always works, never breaks
    {%- endcomment -%}
    {%- liquid
      assign logo_src = null
      assign logo_alt = brand_name
      if shop.brand.logo != blank
        assign logo_src = shop.brand.logo
        assign logo_alt = shop.brand.logo.alt | default: brand_name
      elsif logo_image != blank
        assign logo_src = logo_image
        assign logo_alt = logo_image.alt | default: brand_name
      endif
    -%}
    <a
      href="{{ routes.root_url }}"
      class="header__logo-link"
      aria-label="{{ brand_name }} — {{ 'general.accessibility.home' | t | default: 'Go to homepage' }}"
    >
      {%- if logo_src != null -%}
        {{
          logo_src
          | image_url: width: logo_width
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'header__logo-img',
            alt: logo_alt,
            widths: '80, 80, 160, 240',
            sizes: '(max-width: 900px) 90px, 80px'
        }}
      {%- else -%}
        {%- comment -%} Fallback: brand name as styled text — shown when no logo is set anywhere {%- endcomment -%}
        <span class="header__logo-text" aria-hidden="false">{{ brand_name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} ── DESKTOP NAVIGATION ───────────────────────────────── {%- endcomment -%}
    {%- comment -%}
      Mega-menu logic:
      • Any nav link whose title (case-insensitive) matches section.settings.mega_menu_trigger
        (default "Product" / "Products") renders a MEGA MENU panel instead of a plain dropdown.
      • The mega menu shows collection cards defined in the schema blocks.
      • All other links with children render a standard slim dropdown.
    {%- endcomment -%}
    {%- assign mega_trigger = section.settings.mega_menu_trigger | downcase | strip -%}
    {%- assign mega_trigger_plural = mega_trigger | append: 's' -%}
    <nav
      class="header__nav"
      aria-label="{{ 'general.accessibility.nav_main' | t | default: 'Main navigation' }}"
    >
      <ul class="header__nav-list" role="list">
        {%- if menu != blank and menu.links.size > 0 -%}
          {%- for link in menu.links -%}
            {%- assign link_lower = link.title | downcase | strip -%}
            {%- assign is_mega = false -%}
            {%- if link_lower == mega_trigger or link_lower == mega_trigger_plural -%}
              {%- assign is_mega = true -%}
            {%- endif -%}

            <li class="header__nav-item{% if is_mega %} has-mega{% elsif link.links.size > 0 %} has-dropdown{% endif %}">
              {%- comment -%} Nav link / button ─────────────────────────────── {%- endcomment -%}
              <a
                href="{{ link.url }}"
                class="header__nav-link{% if link.active %} is-active{% endif %}"
                {% if is_mega or link.links.size > 0 %}
                  aria-haspopup="true"
                  aria-expanded="false"
                {% endif %}
                {% if link.current %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title | escape }}
                {%- if is_mega or link.links.size > 0 -%}
                  <span class="header__nav-chevron" aria-hidden="true">
                    <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                      <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- endif -%}
              </a>

              {%- comment -%}
                MEGA MENU panel
                SOURCE PRIORITY:
                  1. link.links  — sub-items added directly in Shopify Navigation (e.g. Makhana, Oil)
                                   Each child link is matched to a collection by handle for image/count.
                  2. schema blocks — Collection Card blocks added in the theme editor (optional override).
                Both work independently; nav children take priority when present.
              {%- endcomment -%}
              {%- if is_mega -%}
                <div class="mega-menu" role="region" aria-label="{{ link.title | escape }} collections">
                  <div class="mega-menu__inner">
                    {%- comment -%} Header row: heading + view-all ─────────── {%- endcomment -%}
                    <div class="mega-menu__header">
                      <p class="mega-menu__heading">
                        {{ section.settings.mega_menu_heading | default: 'Our Products' }}
                      </p>
                      <a href="{{ link.url }}" class="mega-menu__view-all">
                        {{ section.settings.mega_menu_view_all | default: 'View all products' }}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </div>

                    {%- comment -%}
                      CASE 1 — Nav children exist (Shopify Navigation sub-items like Makhana, Oil).
                      We match each child link's title to a collection handle to pull image + count.
                    {%- endcomment -%}
                    {%- if link.links.size > 0 -%}
                      <ul class="mega-menu__grid" role="list">
                        {%- for child_link in link.links -%}
                          {%- comment -%} Derive collection handle from the child URL or title {%- endcomment -%}
                          {%- assign child_handle = child_link.url
                            | split: '/collections/'
                            | last
                            | split: '?'
                            | first
                          -%}
                          {%- assign child_col = collections[child_handle] -%}

                          {%- comment -%} Check if a schema block overrides this child's image/badge {%- endcomment -%}
                          {%- assign override_img = null -%}
                          {%- assign override_badge = null -%}
                          {%- assign override_desc = null -%}
                          {%- for block in section.blocks -%}
                            {%- if block.type == 'collection_card' -%}
                              {%- assign b_col = collections[block.settings.collection] -%}
                              {%- assign b_title = block.settings.label | default: b_col.title | downcase | strip -%}
                              {%- assign c_title = child_link.title | downcase | strip -%}
                              {%- if b_title == c_title or b_col.handle == child_handle -%}
                                {%- assign override_img = block.settings.image -%}
                                {%- assign override_badge = block.settings.badge -%}
                                {%- assign override_desc = block.settings.description -%}
                              {%- endif -%}
                            {%- endif -%}
                          {%- endfor -%}

                          <li class="mega-menu__card">
                            <a
                              href="{{ child_link.url }}"
                              class="mega-menu__card-link{% if child_link.active %} is-active{% endif %}"
                              {% if child_link.current %}
                                aria-current="page"
                              {% endif %}
                            >
                              {%- comment -%} Image: schema override → collection image → first product image → placeholder {%- endcomment -%}
                              <div class="mega-menu__card-img-wrap">
                                {%- if override_img != null and override_img != blank -%}
                                  {{
                                    override_img
                                    | image_url: width: 300
                                    | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: child_link.title
                                  }}
                                {%- elsif child_col != blank and child_col.image != blank -%}
                                  {{
                                    child_col.image
                                    | image_url: width: 300
                                    | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: child_link.title
                                  }}
                                {%- elsif child_col != blank and child_col.products.first.featured_image != blank -%}
                                  {{
                                    child_col.products.first.featured_image
                                    | image_url: width: 300
                                    | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: child_link.title
                                  }}
                                {%- else -%}
                                  <div class="mega-menu__card-placeholder" aria-hidden="true">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                      <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.4"/>
                                      <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                                      <path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                                    </svg>
                                  </div>
                                {%- endif -%}
                                {%- if override_badge != null and override_badge != blank -%}
                                  <span class="mega-menu__card-badge">{{ override_badge }}</span>
                                {%- endif -%}
                              </div>

                              <div class="mega-menu__card-body">
                                <span class="mega-menu__card-title">{{ child_link.title | escape }}</span>
                                {%- if override_desc != null and override_desc != blank -%}
                                  <span class="mega-menu__card-desc">{{ override_desc }}</span>
                                {%- elsif child_col != blank and child_col.description != blank -%}
                                  <span class="mega-menu__card-desc">
                                    {{- child_col.description | strip_html | truncate: 60 -}}
                                  </span>
                                {%- endif -%}
                                {%- if child_col != blank -%}
                                  <span class="mega-menu__card-count">{{ child_col.products_count }} items</span>
                                {%- endif -%}
                              </div>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>

                      {%- comment -%}
                        CASE 2 — No nav children. Fall back to schema Collection Card blocks.
                      {%- endcomment -%}
                    {%- elsif section.blocks.size > 0 -%}
                      <ul class="mega-menu__grid" role="list">
                        {%- for block in section.blocks -%}
                          {%- if block.type == 'collection_card' -%}
                            {%- assign col = collections[block.settings.collection] -%}
                            {%- assign card_url = col.url | default: block.settings.custom_url | default: link.url -%}
                            {%- assign card_title = block.settings.label
                              | default: col.title
                              | default: 'Collection'
                            -%}
                            {%- assign card_desc = block.settings.description
                              | default: col.description
                              | strip_html
                              | truncate: 60
                            -%}
                            <li class="mega-menu__card" {{ block.shopify_attributes }}>
                              <a href="{{ card_url }}" class="mega-menu__card-link">
                                <div class="mega-menu__card-img-wrap">
                                  {%- if block.settings.image != blank -%}
                                    {{
                                      block.settings.image
                                      | image_url: width: 300
                                      | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: card_title
                                    }}
                                  {%- elsif col != blank and col.image != blank -%}
                                    {{
                                      col.image
                                      | image_url: width: 300
                                      | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: card_title
                                    }}
                                  {%- elsif col != blank and col.products.first.featured_image != blank -%}
                                    {{
                                      col.products.first.featured_image
                                      | image_url: width: 300
                                      | image_tag: loading: 'lazy', class: 'mega-menu__card-img', alt: card_title
                                    }}
                                  {%- else -%}
                                    <div class="mega-menu__card-placeholder" aria-hidden="true">
                                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                        <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.4"/>
                                        <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                                        <path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                                      </svg>
                                    </div>
                                  {%- endif -%}
                                  {%- if block.settings.badge != blank -%}
                                    <span class="mega-menu__card-badge">{{ block.settings.badge }}</span>
                                  {%- endif -%}
                                </div>
                                <div class="mega-menu__card-body">
                                  <span class="mega-menu__card-title">{{ card_title }}</span>
                                  {%- if card_desc != blank -%}
                                    <span class="mega-menu__card-desc">{{ card_desc }}</span>
                                  {%- endif -%}
                                  {%- if col != blank -%}
                                    <span class="mega-menu__card-count">{{ col.products_count }} items</span>
                                  {%- endif -%}
                                </div>
                              </a>
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>

                      {%- comment -%}
                        CASE 3 — Nothing configured yet. Show setup instructions.
                      {%- endcomment -%}
                    {%- else -%}
                      <p class="mega-menu__empty">
                        Add sub-items to the "{{ link.title }}" nav link in <strong>Online Store → Navigation</strong>,
                        or add Collection Card blocks in the theme editor.
                      </p>
                    {%- endif -%}
                  </div>
                </div>

                {%- comment -%} STANDARD slim dropdown ──────────────────────────── {%- endcomment -%}
              {%- elsif link.links.size > 0 -%}
                <ul class="header__dropdown" role="list" aria-label="{{ link.title | escape }} submenu">
                  {%- for child_link in link.links -%}
                    <li>
                      <a
                        href="{{ child_link.url }}"
                        class="header__dropdown-link{% if child_link.active %} is-active{% endif %}"
                        {% if child_link.current %}
                          aria-current="page"
                        {% endif %}
                      >
                        {{ child_link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Graceful fallback when menu is empty or missing {%- endcomment -%}
          <li class="header__nav-item">
            <a href="{{ routes.root_url }}" class="header__nav-link is-active">Home</a>
          </li>
        {%- endif -%}
      </ul>
    </nav>

    {%- comment -%} ── ICON ACTIONS ─────────────────────────────────────── {%- endcomment -%}
    <div
      class="header__actions"
      role="group"
      aria-label="{{ 'general.accessibility.actions' | t | default: 'Site actions' }}"
    >
      {%- comment -%} Search {%- endcomment -%}
      <button
        class="header__icon-btn header__icon-btn--search"
        aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
        data-search-toggle
        type="button"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
          <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>

      {%- comment -%} Account {%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon-btn"
          aria-label="{%- if customer -%}{{ 'customer.account.title' | t | default: 'My Account' }}{%- else -%}{{ 'customer.login.title' | t | default: 'Log in' }}{%- endif -%}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </a>
      {%- endif -%}

      {%- comment -%} Wishlist (works with Wishlist Hero, Growave, or custom) {%- endcomment -%}
      <a
        href="/pages/wishlist"
        class="header__icon-btn header__icon-btn--wishlist"
        aria-label="{{ 'wishlist.general.wishlist' | t | default: 'Wishlist' }}"
        data-wishlist-link
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 21C12 21 3 14.5 3 8.5A5.5 5.5 0 0 1 12 5.17 5.5 5.5 0 0 1 21 8.5C21 14.5 12 21 12 21Z"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {%- comment -%} Wishlist count badge — populated by app JS {%- endcomment -%}
        <span
          class="header__badge header__badge--wishlist"
          data-wishlist-count
          aria-live="polite"
          aria-label="wishlist count"
          hidden
          >0</span
        >
      </a>

      {%- comment -%} Cart {%- endcomment -%}
      <a
        href="{{ routes.cart_url }}"
        class="header__icon-btn header__icon-btn--cart"
        aria-label="{{ 'cart.general.title' | t | default: 'Cart' }} ({{ cart.item_count }} {{ 'cart.general.item_count' | t: count: cart.item_count | default: 'items' }})"
        data-cart-link
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M1 1h3l1.68 8.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L21 5H5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
          <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__badge header__badge--cart" aria-hidden="true">
            {{ cart.item_count | at_most: 99 -}}
            {%- if cart.item_count > 99 %}+{% endif %}
          </span>
        {%- endif -%}
      </a>

      {%- comment -%} Hamburger — mobile only {%- endcomment -%}
      <button
        class="header__hamburger"
        aria-label="{{ 'general.accessibility.menu' | t | default: 'Open menu' }}"
        aria-expanded="false"
        aria-controls="mobile-nav-drawer"
        data-hamburger
        type="button"
      >
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
      </button>
    </div>
    {%- comment -%} /.header__actions {%- endcomment -%}
  </div>
  {%- comment -%} /.header__inner {%- endcomment -%}

  {%- comment -%} ── SEARCH OVERLAY ───────────────────────────────────────── {%- endcomment -%}
  <div class="header__search-overlay" data-search-overlay aria-hidden="true" role="search">
    <div class="search-overlay__inner">
      <form action="{{ routes.search_url }}" method="get" class="search-overlay__form" role="search">
        <input type="hidden" name="type" value="product,article,page">
        <label for="header-search-input" class="sr-only">
          {{- 'general.search.placeholder' | t | default: 'Search' -}}
        </label>
        <input
          id="header-search-input"
          type="search"
          name="q"
          class="search-overlay__input"
          placeholder="{{ 'general.search.placeholder' | t | default: 'Search products…' }}"
          autocomplete="off"
          aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
        >
        <button
          type="submit"
          class="search-overlay__submit"
          aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
            <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
      </form>
      <button
        class="search-overlay__close"
        data-search-close
        type="button"
        aria-label="{{ 'general.accessibility.close' | t | default: 'Close search' }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{%- comment -%} ── MOBILE NAVIGATION DRAWER ─────────────────────────────── {%- endcomment -%}
<div
  id="mobile-nav-drawer"
  class="mobile-drawer"
  aria-label="{{ 'general.accessibility.nav_main' | t | default: 'Mobile menu' }}"
  aria-hidden="true"
  role="dialog"
  data-mobile-drawer
>
  <div class="mobile-drawer__overlay" data-drawer-overlay tabindex="-1"></div>
  <nav class="mobile-drawer__panel" tabindex="-1">
    <div class="mobile-drawer__header">
      <a href="{{ routes.root_url }}" class="mobile-drawer__logo-link">
        {%- if logo_src != null -%}
          {{
            logo_src
            | image_url: width: 100
            | image_tag: loading: 'lazy', class: 'mobile-drawer__logo', alt: logo_alt
          }}
        {%- else -%}
          <span class="mobile-drawer__brand">{{ brand_name }}</span>
        {%- endif -%}
      </a>
      <button
        class="mobile-drawer__close"
        aria-label="{{ 'general.accessibility.close' | t | default: 'Close menu' }}"
        data-drawer-close
        type="button"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <ul class="mobile-drawer__list" role="list">
      {%- if menu != blank and menu.links.size > 0 -%}
        {%- for link in menu.links -%}
          {%- assign link_lower = link.title | downcase | strip -%}
          {%- assign is_mega_mob = false -%}
          {%- if link_lower == mega_trigger or link_lower == mega_trigger_plural -%}
            {%- assign is_mega_mob = true -%}
          {%- endif -%}

          <li class="mobile-drawer__item{% if is_mega_mob or link.links.size > 0 %} has-children{% endif %}">
            {%- comment -%}
              MEGA mobile: reads nav children first (e.g. Makhana, Oil from Navigation),
              falls back to schema blocks if no nav children exist.
            {%- endcomment -%}
            {%- if is_mega_mob -%}
              <button
                class="mobile-drawer__link mobile-drawer__link--parent"
                aria-expanded="false"
                data-mobile-parent
                type="button"
              >
                {{ link.title | escape }}
                <svg
                  class="mobile-drawer__chevron"
                  width="12"
                  height="8"
                  viewBox="0 0 12 8"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="mobile-drawer__children mobile-drawer__children--collections" role="list" hidden>
                {%- comment -%} CASE 1: Nav children (Shopify Navigation sub-items) {%- endcomment -%}
                {%- if link.links.size > 0 -%}
                  {%- for child_link in link.links -%}
                    {%- assign child_handle = child_link.url | split: '/collections/' | last | split: '?' | first -%}
                    {%- assign child_col = collections[child_handle] -%}
                    {%- comment -%} Check for schema block image/badge override {%- endcomment -%}
                    {%- assign mob_img = null -%}
                    {%- assign mob_badge = null -%}
                    {%- for block in section.blocks -%}
                      {%- if block.type == 'collection_card' -%}
                        {%- assign b_col = collections[block.settings.collection] -%}
                        {%- assign b_title = block.settings.label | default: b_col.title | downcase | strip -%}
                        {%- assign c_title = child_link.title | downcase | strip -%}
                        {%- if b_title == c_title or b_col.handle == child_handle -%}
                          {%- assign mob_img = block.settings.image -%}
                          {%- assign mob_badge = block.settings.badge -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <li>
                      <a
                        href="{{ child_link.url }}"
                        class="mobile-drawer__child-link mobile-drawer__child-link--collection"
                      >
                        {%- if mob_img != null and mob_img != blank -%}
                          {{
                            mob_img
                            | image_url: width: 56
                            | image_tag: loading: 'lazy', class: 'mobile-drawer__col-thumb', alt: child_link.title
                          }}
                        {%- elsif child_col != blank and child_col.image != blank -%}
                          {{
                            child_col.image
                            | image_url: width: 56
                            | image_tag: loading: 'lazy', class: 'mobile-drawer__col-thumb', alt: child_link.title
                          }}
                        {%- elsif child_col != blank and child_col.products.first.featured_image != blank -%}
                          {{
                            child_col.products.first.featured_image
                            | image_url: width: 56
                            | image_tag: loading: 'lazy', class: 'mobile-drawer__col-thumb', alt: child_link.title
                          }}
                        {%- else -%}
                          <span
                            class="mobile-drawer__col-thumb mobile-drawer__col-thumb--placeholder"
                            aria-hidden="true"
                          >
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                              <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.4"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                            </svg>
                          </span>
                        {%- endif -%}
                        <span class="mobile-drawer__col-label">
                          {{ child_link.title | escape }}
                          {%- if mob_badge != null and mob_badge != blank -%}
                            <em class="mobile-drawer__col-badge">{{ mob_badge }}</em>
                          {%- endif -%}
                        </span>
                        <svg
                          width="10"
                          height="10"
                          viewBox="0 0 24 24"
                          fill="none"
                          aria-hidden="true"
                          class="mobile-drawer__col-arrow"
                        >
                          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </li>
                  {%- endfor -%}

                  {%- comment -%} CASE 2: Fall back to schema blocks {%- endcomment -%}
                {%- elsif section.blocks.size > 0 -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'collection_card' -%}
                      {%- assign col = collections[block.settings.collection] -%}
                      {%- assign card_url = col.url | default: block.settings.custom_url | default: link.url -%}
                      {%- assign card_title = block.settings.label | default: col.title | default: 'Collection' -%}
                      <li>
                        <a
                          href="{{ card_url }}"
                          class="mobile-drawer__child-link mobile-drawer__child-link--collection"
                        >
                          {%- if block.settings.image != blank -%}
                            {{
                              block.settings.image
                              | image_url: width: 56
                              | image_tag: loading: 'lazy', class: 'mobile-drawer__col-thumb', alt: card_title
                            }}
                          {%- elsif col != blank and col.image != blank -%}
                            {{
                              col.image
                              | image_url: width: 56
                              | image_tag: loading: 'lazy', class: 'mobile-drawer__col-thumb', alt: card_title
                            }}
                          {%- else -%}
                            <span
                              class="mobile-drawer__col-thumb mobile-drawer__col-thumb--placeholder"
                              aria-hidden="true"
                            >
                              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.4"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                              </svg>
                            </span>
                          {%- endif -%}
                          <span class="mobile-drawer__col-label">
                            {{ card_title }}
                            {%- if block.settings.badge != blank -%}
                              <em class="mobile-drawer__col-badge">{{ block.settings.badge }}</em>
                            {%- endif -%}
                          </span>
                          <svg
                            width="10"
                            height="10"
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                            class="mobile-drawer__col-arrow"
                          >
                            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </a>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                {%- comment -%} Always show View all at the bottom {%- endcomment -%}
                <li>
                  <a href="{{ link.url }}" class="mobile-drawer__child-link mobile-drawer__child-link--view-all">
                    {{ section.settings.mega_menu_view_all | default: 'View all products' }} →
                  </a>
                </li>
              </ul>

              {%- comment -%} STANDARD child links {%- endcomment -%}
            {%- elsif link.links.size > 0 -%}
              <button
                class="mobile-drawer__link mobile-drawer__link--parent"
                aria-expanded="false"
                data-mobile-parent
                type="button"
              >
                {{ link.title | escape }}
                <svg
                  class="mobile-drawer__chevron"
                  width="12"
                  height="8"
                  viewBox="0 0 12 8"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="mobile-drawer__children" role="list" hidden>
                {%- for child_link in link.links -%}
                  <li>
                    <a
                      href="{{ child_link.url }}"
                      class="mobile-drawer__child-link{% if child_link.active %} is-active{% endif %}"
                    >
                      {{- child_link.title | escape -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>

              {%- comment -%} PLAIN link {%- endcomment -%}
            {%- else -%}
              <a
                href="{{ link.url }}"
                class="mobile-drawer__link{% if link.active %} is-active{% endif %}"
              >
                {{- link.title | escape -}}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- else -%}
        <li class="mobile-drawer__item">
          <a href="{{ routes.root_url }}" class="mobile-drawer__link is-active">Home</a>
        </li>
      {%- endif -%}
    </ul>

    <div class="mobile-drawer__footer">
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="mobile-drawer__footer-link"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          {%- if customer -%}
            {{ 'customer.account.title' | t | default: 'My Account' }}
          {%- else -%}
            {{ 'customer.login.title' | t | default: 'Log in' }}
          {%- endif -%}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="mobile-drawer__footer-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M1 1h3l1.68 8.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L21 5H5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
          <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
        </svg>
        {{ 'cart.general.title' | t | default: 'Cart' }}
        {%- comment -%} Server-rendered count — always correct on load. JS keeps it live after AJAX mutations. {%- endcomment -%}
        <span
          class="mobile-drawer__cart-count"
          data-drawer-cart-count
          {% if cart.item_count == 0 %}
            style="display:none"
          {% endif %}
          >({{ cart.item_count }})</span
        >
      </a>
    </div>
  </nav>
</div>

{%- comment -%} ── STYLES ───────────────────────────────────────────────── {%- endcomment -%}

{%- comment -%} ── JAVASCRIPT ───────────────────────────────────────────── {%- endcomment -%}
<script>
  (function () {
    'use strict';

    // ── Element refs ──────────────────────────────────────────────────────────
    const header = document.querySelector('[data-header]');
    const hamburger = document.querySelector('[data-hamburger]');
    const drawer = document.querySelector('[data-mobile-drawer]');
    const drawerOverlay = document.querySelector('[data-drawer-overlay]');
    const drawerClose = document.querySelector('[data-drawer-close]');
    const drawerPanel = drawer ? drawer.querySelector('.mobile-drawer__panel') : null;
    const searchToggle = document.querySelector('[data-search-toggle]');
    const searchOverlay = document.querySelector('[data-search-overlay]');
    const searchClose = document.querySelector('[data-search-close]');
    const searchInput = document.querySelector('#header-search-input');
    const mobileParents = document.querySelectorAll('[data-mobile-parent]');

    // Guard: exit early if header is missing (error resilience)
    if (!header) return;

    // ── Drawer helpers ────────────────────────────────────────────────────────
    function openDrawer() {
      if (!drawer || !hamburger) return;
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      drawerPanel && drawerPanel.focus();
      trapFocus(drawer);
    }

    function closeDrawer() {
      if (!drawer || !hamburger) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      hamburger.focus();
      releaseFocus();
    }

    hamburger && hamburger.addEventListener('click', openDrawer);
    drawerOverlay && drawerOverlay.addEventListener('click', closeDrawer);
    drawerClose && drawerClose.addEventListener('click', closeDrawer);

    // ── Search overlay ────────────────────────────────────────────────────────
    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.add('is-open');
      searchOverlay.setAttribute('aria-hidden', 'false');
      searchInput && requestAnimationFrame(() => searchInput.focus());
    }

    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      searchToggle && searchToggle.focus();
    }

    searchToggle && searchToggle.addEventListener('click', openSearch);
    searchClose && searchClose.addEventListener('click', closeSearch);

    // ── Mobile accordion parents ──────────────────────────────────────────────
    mobileParents.forEach(function (btn) {
      btn.addEventListener('click', function () {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const children = btn.nextElementSibling;
        btn.setAttribute('aria-expanded', String(!expanded));
        if (children) {
          if (expanded) {
            children.setAttribute('hidden', '');
          } else {
            children.removeAttribute('hidden');
          }
        }
      });
    });

    // ── Keyboard: ESC closes drawer / search ─────────────────────────────────
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      if (drawer && drawer.classList.contains('is-open')) closeDrawer();
      if (searchOverlay && searchOverlay.classList.contains('is-open')) closeSearch();
    });

    // ── Focus trap (drawer) ───────────────────────────────────────────────────
    var _focusTrapEl = null;
    var _focusHandler = null;

    function trapFocus(el) {
      _focusTrapEl = el;
      _focusHandler = function (e) {
        var focusable = el.querySelectorAll(
          'a[href], button:not([disabled]), input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.key === 'Tab') {
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      };
      el.addEventListener('keydown', _focusHandler);
    }

    function releaseFocus() {
      if (_focusTrapEl && _focusHandler) {
        _focusTrapEl.removeEventListener('keydown', _focusHandler);
      }
      _focusTrapEl = null;
      _focusHandler = null;
    }

    // ── Wishlist badge (app-agnostic hook) ────────────────────────────────────
    // Many wishlist apps dispatch a custom event; we listen and update the badge.
    document.addEventListener('wishlist:updated', function (e) {
      var badge = document.querySelector('[data-wishlist-count]');
      if (!badge) return;
      var count = (e.detail && e.detail.count) || 0;
      badge.textContent = count > 99 ? '99+' : String(count);
      badge.hidden = count === 0;
    });

    // ── Cart bubble: live update via Shopify AJAX ─────────────────────────────
    // Updates BOTH the header badge AND the mobile drawer count span in one place.
    function syncCartCount(count) {
      // Header badge (desktop + mobile icon)
      var badge = document.querySelector('.header__badge--cart');
      if (badge) {
        badge.textContent = count > 99 ? '99+' : String(count);
        badge.style.display = count === 0 ? 'none' : '';
      }
      // Mobile drawer footer cart count
      var drawerCount = document.querySelector('[data-drawer-cart-count]');
      if (drawerCount) {
        drawerCount.textContent = '(' + count + ')';
        drawerCount.style.display = count === 0 ? 'none' : '';
      }
    }

    // Listen for Shopify theme cart:updated events (works with most themes & apps)
    document.addEventListener('cart:updated', function (e) {
      var count = (e.detail && (e.detail.itemCount || (e.detail.cart && e.detail.cart.item_count))) || 0;
      syncCartCount(count);
    });

    // Also handle Shopify's native sections:load and fetch cart on init to verify count
    (function verifyCartCount() {
      fetch('/cart.js')
        .then(function (r) {
          return r.json();
        })
        .then(function (cart) {
          syncCartCount(cart.item_count || 0);
        })
        .catch(function () {
          /* silently fail — server-rendered count remains */
        });
    })();
  })();
</script>

{%- comment -%} ── SCHEMA ───────────────────────────────────────────────── {%- endcomment -%}
{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-header",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Recommended: SVG or PNG with transparent background. Falls back to shop brand logo, then brand name text."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (logo fallback)",
      "default": "Meluha Foods",
      "info": "Shown as text only when no logo image is set anywhere."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "header",
      "content": "Mega Menu — Products Dropdown"
    },
    {
      "type": "text",
      "id": "mega_menu_trigger",
      "label": "Nav link title that opens mega menu",
      "default": "Product",
      "info": "Must match your nav link title exactly (case-insensitive). Works for both 'Product' and 'Products'."
    },
    {
      "type": "text",
      "id": "mega_menu_heading",
      "label": "Mega menu heading",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "mega_menu_view_all",
      "label": "'View all' link label",
      "default": "View all products"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Links to this collection page automatically."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Card title (optional override)",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description (optional)",
          "info": "Max ~60 characters shown. Leave blank to hide."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image (optional override)",
          "info": "Leave blank to use the collection image automatically."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge label (optional)",
          "info": "E.g. 'New', 'Sale', 'Bestseller'. Leave blank to hide."
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom URL (optional override)",
          "info": "Leave blank to use the collection URL automatically."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [{ "type": "collection_card" }, { "type": "collection_card" }, { "type": "collection_card" }]
    }
  ]
}
{% endschema %}
