{% comment %}
  Social Media Review Slider (Production Ready)
{% endcomment %}

<section class="social-slider">
  <div class="social-container">
    {% if section.settings.logo %}
      <div class="social-logo">
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="" width="" height="">
      </div>
    {% endif %}

    <div class="swiper socialSwiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide">
            <div class="social-card">
              <!-- HEADER -->
              <div class="social-header">
                <div class="social-user">
                  {% if block.settings.avatar %}
                    <img src="{{ block.settings.avatar | image_url: width: 80 }}" class="avatar" width="" height="">
                  {% endif %}
                  <div class="review-info">
                    <p class="username">{{ block.settings.username }}</p>
                    <p class="sub">All Indians favourite</p>
                  </div>
                </div>
                {% comment %} <span class="menu">⋮</span> {% endcomment %}
              </div>

              <!-- IMAGE -->
              <div class="social-image">
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="" width="" height="">
                {% endif %}
              </div>

              <!-- ACTIONS -->
              <div class="social-actions">❤️ 💬 ✈️</div>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<style>
  .social-slider {
    padding: 60px 20px;
    background: #f5f5f5;
  }

  .social-container {
    max-width: 1400px;
    margin: auto;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  /* LOGO */
  .social-logo img {
    width: 120px;
    max-width: 100%;
  }

  /* CARD */
  .social-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
  }

  /* HEADER */
  .social-header {
    display: flex;
    justify-content: space-between;
    padding: 10px;
  }

  .social-user {
    display: flex;
    gap: 1px;
    align-items: center;
  }

  .avatar {
    width: 35px;
    height: 35px;
    border-radius: 50%;
  }

  .username {
    font-size: 14px;
    font-weight: 600;
  }

  .review-info {
    line-height: 1px;
    padding-left: 10px;
  }
  .sub {
    font-size: 14px;
    line-height: 1px;
    padding: 0;
  }
  .username {
    font-size: 1.2rem;
  }
  /* IMAGE */
  .social-image {
    width: 100%;
    aspect-ratio: 4 / 5; /* 🔥 better than fixed height */
  }

  .social-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ACTIONS */
  .social-actions {
    padding: 12px;
    font-size: 18px;
  }

  .swiper-wrapper {
    align-items: stretch;
  }

  .socialSwiper {
    width: 100%;
    overflow: hidden;
  }

  /* SLIDER EFFECT */
  .socialSwiper .swiper-slide {
    transition: 0.3s;
    opacity: 0.4;
    transform: scale(0.85);
  }

  .socialSwiper .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
  }

  /* 🔥 RESPONSIVE */

  /* Tablet */
  @media (max-width: 1024px) {
    .social-container {
      flex-direction: column;
      gap: 10px;
    }

    .social-logo {
      display: none;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .social-slider {
      padding: 40px 10px;
    }
  }

  /* Big screens */
  @media (min-width: 1600px) {
    .social-container {
      max-width: 1600px;
    }
  }
</style>

<script>
  function initSocialSwiper() {
    const el = document.querySelector('.socialSwiper');
    if (!el) return;

    // Prevent duplicate init (Shopify reload fix)
    if (el.classList.contains('swiper-initialized')) return;

    new Swiper(el, {
      slidesPerView: 1.2,
      centeredSlides: true,
      spaceBetween: 15,
      loop: true,

      autoplay: {
        delay: 2500, // ❌ remove 0 → causes bugs
        disableOnInteraction: false,
      },

      speed: 800, // ❌ reduce from 4000 → smoother + stable

      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },

      breakpoints: {
        0: {
          slidesPerView: 1.1,
          centeredSlides: false, // 🔥 fix
        },
        480: {
          slidesPerView: 1.3,
          centeredSlides: false,
        },
        768: {
          slidesPerView: 2,
          centeredSlides: false,
        },
        1024: {
          slidesPerView: 3,
          centeredSlides: true,
        },
        1400: {
          slidesPerView: 4,
          centeredSlides: true,
        },
      },
    });
  }

  // Initial load
  document.addEventListener('DOMContentLoaded', initSocialSwiper);

  // Shopify section reload fix (CRITICAL)
  document.addEventListener('shopify:section:load', initSocialSwiper);
</script>

{% schema %}
{
  "name": "Reel Slider",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Side Logo"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "User Avatar"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Username"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reel Slider"
    }
  ]
}
{% endschema %}
