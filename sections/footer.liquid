{{ 'footer.css' | asset_url | stylesheet_tag }}
{% comment %}
  Meluha Foods — Production Footer
  Sections: Brand col, Support, Account, Quick Links, Exclusive (newsletter)
  Fully responsive: 5-col desktop → 3-col tablet → 2-col mobile → 1-col small phone (collapsible)
  All content editable via theme editor schema.
  Error handling: logo fallback, empty link list fallback, social icon fallback.
{% endcomment %}

{%- liquid
  assign brand_name = section.settings.brand_name | default: shop.name
  assign tagline = section.settings.tagline | default: ''
  assign logo_width = section.settings.logo_width | default: 120
  assign address = section.settings.address | default: ''
  assign email = section.settings.contact_email | default: ''
  assign phone = section.settings.contact_phone | default: ''
  assign copy_text = section.settings.copyright | default: ''

  assign acct_menu = linklists[section.settings.account_menu]
  assign quick_menu = linklists[section.settings.quick_menu]

  assign logo_src = null
  assign logo_alt = brand_name
  if shop.brand.logo != blank
    assign logo_src = shop.brand.logo
    assign logo_alt = shop.brand.logo.alt | default: brand_name
  elsif section.settings.logo != blank
    assign logo_src = section.settings.logo
    assign logo_alt = section.settings.logo.alt | default: brand_name
  endif
-%}

<footer class="site-footer" role="contentinfo">
  <div class="footer__inner">
    {%- comment -%} ══ COL 1 — Brand ═══════════════════════════════════════ {%- endcomment -%}
    <div class="footer__col footer__col--brand">
      <a href="{{ routes.root_url }}" class="footer__logo-link" aria-label="{{ brand_name }} — home">
        {%- if logo_src != null -%}
          {{
            logo_src
            | image_url: width: logo_width
            | image_tag:
              loading: 'lazy',
              class: 'footer__logo-img',
              alt: logo_alt,
              widths: '80, 120, 160',
              sizes: '120px'
          }}
        {%- else -%}
          <span class="footer__logo-text">{{ brand_name }}</span>
        {%- endif -%}
      </a>

      {%- if tagline != blank -%}
        <p class="footer__tagline">{{ tagline }}</p>
      {%- endif -%}

      {%- comment -%} Social icons ─────────────────────────────────────────── {%- endcomment -%}
      {%- assign has_social = false -%}
      {%- if section.settings.social_instagram != blank
        or section.settings.social_twitter != blank
        or section.settings.social_facebook != blank
        or section.settings.social_linkedin != blank
      -%}
        {%- assign has_social = true -%}
      {%- endif -%}

      {%- if has_social -%}
        <div class="footer__social">
          <p class="footer__social-label">{{ section.settings.social_label | default: 'Follow Us On' }}</p>
          <ul class="footer__social-list" role="list">
            {%- if section.settings.social_instagram != blank -%}
              <li>
                <a
                  href="{{ section.settings.social_instagram }}"
                  class="footer__social-link footer__social-link--instagram"
                  aria-label="Instagram"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <li>
                <a
                  href="{{ section.settings.social_twitter }}"
                  class="footer__social-link footer__social-link--twitter"
                  aria-label="Twitter / X"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_facebook != blank -%}
              <li>
                <a
                  href="{{ section.settings.social_facebook }}"
                  class="footer__social-link footer__social-link--facebook"
                  aria-label="Facebook"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_linkedin != blank -%}
              <li>
                <a
                  href="{{ section.settings.social_linkedin }}"
                  class="footer__social-link footer__social-link--linkedin"
                  aria-label="LinkedIn"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ══ COL 2 — Support ═════════════════════════════════════ {%- endcomment -%}
    <div class="footer__col footer__col--support">
      <h3 class="footer__col-heading" id="footer-support-heading">
        {{ section.settings.support_heading | default: 'Support' }}
      </h3>
      <div class="footer__collapsible" aria-labelledby="footer-support-heading">
        <ul class="footer__contact-list" role="list">
          {%- if address != blank -%}
            <li class="footer__contact-item">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
                class="footer__contact-icon"
              >
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6"/>
              </svg>
              <span>{{ address }}</span>
            </li>
          {%- endif -%}
          {%- if email != blank -%}
            <li class="footer__contact-item">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
                class="footer__contact-icon"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
              <a href="mailto:{{ email }}" class="footer__contact-link">{{ email }}</a>
            </li>
          {%- endif -%}
          {%- if phone != blank -%}
            <li class="footer__contact-item">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
                class="footer__contact-icon"
              >
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.02l-2.2 2.2z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <a href="tel:{{ phone | remove: ' ' }}" class="footer__contact-link">{{ phone }}</a>
            </li>
          {%- endif -%}
          {%- if address == blank and email == blank and phone == blank -%}
            <li class="footer__contact-item">
              <span style="color:var(--ftr-text-muted)">Contact details coming soon.</span>
            </li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ══ COL 3 — Account ═════════════════════════════════════ {%- endcomment -%}
    <div class="footer__col footer__col--account">
      <h3 class="footer__col-heading" id="footer-account-heading">
        {{ section.settings.account_heading | default: 'Account' }}
      </h3>
      <div class="footer__collapsible" aria-labelledby="footer-account-heading">
        <ul class="footer__nav-list" role="list">
          {%- if acct_menu != blank and acct_menu.links.size > 0 -%}
            {%- for link in acct_menu.links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="footer__nav-link{% if link.active %} is-active{% endif %}"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="{{ routes.account_url }}" class="footer__nav-link">My Account</a></li>
            {%- if customer -%}
              <li><a href="{{ routes.account_logout_url }}" class="footer__nav-link">Log out</a></li>
            {%- else -%}
              <li><a href="{{ routes.account_login_url }}" class="footer__nav-link">Login / Register</a></li>
            {%- endif -%}
            <li><a href="{{ routes.cart_url }}" class="footer__nav-link">Cart</a></li>
            <li><a href="/pages/wishlist" class="footer__nav-link">Wishlist</a></li>
            <li><a href="{{ routes.all_products_collection_url }}" class="footer__nav-link">Shop</a></li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ══ COL 4 — Quick Links ══════════════════════════════════ {%- endcomment -%}
    <div class="footer__col footer__col--quick">
      <h3 class="footer__col-heading" id="footer-quick-heading">
        {{ section.settings.quick_heading | default: 'Quick Link' }}
      </h3>
      <div class="footer__collapsible" aria-labelledby="footer-quick-heading">
        <ul class="footer__nav-list" role="list">
          {%- if quick_menu != blank and quick_menu.links.size > 0 -%}
            {%- for link in quick_menu.links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="footer__nav-link{% if link.active %} is-active{% endif %}"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/policies/privacy-policy" class="footer__nav-link">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service" class="footer__nav-link">Terms Of Use</a></li>
            <li><a href="/pages/about-us" class="footer__nav-link">About Us</a></li>
            <li><a href="/pages/contact" class="footer__nav-link">Contact</a></li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ══ COL 5 — Exclusive / Newsletter ═══════════════════════ {%- endcomment -%}
    <div class="footer__col footer__col--exclusive">
      <h3 class="footer__col-heading">{{ section.settings.exclusive_heading | default: 'Exclusive' }}</h3>
      <p class="footer__subscribe-label">{{ section.settings.subscribe_heading | default: 'Subscribe' }}</p>
      <p class="footer__subscribe-desc">
        {{ section.settings.subscribe_desc | default: 'Get 10% off your first order' }}
      </p>

      {%- form 'customer', id: 'footer-newsletter-form', class: 'footer__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="footer__newsletter-row">
          <label for="footer-email-input" class="sr-only">
            {{- 'general.newsletter_form.email_placeholder' | t | default: 'Enter your email' -}}
          </label>
          <input
            id="footer-email-input"
            type="email"
            name="contact[email]"
            class="footer__newsletter-input"
            placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
            autocomplete="email"
            required
            aria-required="true"
            aria-describedby="footer-nl-status"
          >
          <button
            type="submit"
            class="footer__newsletter-btn"
            aria-label="{{ 'general.newsletter_form.submit' | t | default: 'Subscribe' }}"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p id="footer-nl-status" class="footer__nl-msg footer__nl-msg--success" role="status" aria-live="polite">
            {{ 'general.newsletter_form.confirmation' | t | default: '✓ Thanks for subscribing!' }}
          </p>
        {%- elsif form.errors -%}
          <p id="footer-nl-status" class="footer__nl-msg footer__nl-msg--error" role="alert" aria-live="assertive">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- else -%}
          <span id="footer-nl-status" class="sr-only" aria-live="polite"></span>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  {%- comment -%} ── Bottom bar ──────────────────────────────────────────── {%- endcomment -%}
  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__copyright">
        {%- if copy_text != blank -%}
          {{ copy_text }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }}
          {{ brand_name }}. All rights reserved.
        {%- endif -%}
      </p>
      {% comment %}
        {%- if section.settings.show_payment_icons -%}
          <div class="footer__payment-icons" aria-label="Accepted payment methods">
            {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'footer__payment-icon' }}
          </div>
        {%- endif -%}
      {% endcomment %}
    </div>
  </div>
</footer>

<script>
  (function () {
    'use strict';

    var MOBILE_BP = window.matchMedia('(max-width: 480px)');

    var COLLAPSIBLE_COLS = ['.footer__col--support', '.footer__col--account', '.footer__col--quick'];

    function setupCollapsible() {
      var isMobile = MOBILE_BP.matches;

      COLLAPSIBLE_COLS.forEach(function (sel) {
        var col = document.querySelector(sel);
        if (!col) return;
        var heading = col.querySelector('.footer__col-heading');
        var body = col.querySelector('.footer__collapsible');
        if (!heading || !body) return;

        if (isMobile) {
          // Make heading interactive
          if (!heading.dataset.collapsible) {
            heading.dataset.collapsible = '1';
            heading.setAttribute('role', 'button');
            heading.setAttribute('tabindex', '0');
            heading.setAttribute('aria-expanded', 'false');

            heading.addEventListener('click', toggle);
            heading.addEventListener('keydown', function (e) {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                toggle();
              }
            });
          }
        } else {
          // Desktop: always open
          heading.classList.remove('is-open');
          body.classList.add('is-open');
          heading.removeAttribute('aria-expanded');
        }

        function toggle() {
          var open = heading.classList.toggle('is-open');
          body.classList.toggle('is-open', open);
          heading.setAttribute('aria-expanded', String(open));
        }
      });
    }

    // Init
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupCollapsible);
    } else {
      setupCollapsible();
    }

    // On resize (debounced)
    var timer;
    MOBILE_BP.addEventListener('change', function () {
      clearTimeout(timer);
      timer = setTimeout(setupCollapsible, 80);
    });
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Brand" },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Falls back to shop brand logo, then brand name text."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 200,
      "step": 4,
      "default": 120
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (fallback)",
      "default": "Meluha Foods"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline / description",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry."
    },
    { "type": "header", "content": "Support Column" },
    { "type": "text", "id": "support_heading", "label": "Heading", "default": "Support" },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "111 Bijoy sarani, Dhaka, DH 1515, Bangladesh."
    },
    { "type": "text", "id": "contact_email", "label": "Email", "default": "exclusive@gmail.com" },
    { "type": "text", "id": "contact_phone", "label": "Phone", "default": "+88015-88888-9999" },
    { "type": "header", "content": "Account Column" },
    { "type": "text", "id": "account_heading", "label": "Heading", "default": "Account" },
    {
      "type": "link_list",
      "id": "account_menu",
      "label": "Account menu",
      "info": "Falls back to default account links if blank."
    },
    { "type": "header", "content": "Quick Links Column" },
    { "type": "text", "id": "quick_heading", "label": "Heading", "default": "Quick Link" },
    {
      "type": "link_list",
      "id": "quick_menu",
      "label": "Quick links menu",
      "info": "Falls back to default policy links if blank."
    },
    { "type": "header", "content": "Newsletter Column" },
    { "type": "text", "id": "exclusive_heading", "label": "Heading", "default": "Exclusive" },
    { "type": "text", "id": "subscribe_heading", "label": "Subscribe label", "default": "Subscribe" },
    { "type": "text", "id": "subscribe_desc", "label": "Description", "default": "Get 10% off your first order" },
    { "type": "text", "id": "newsletter_placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "header", "content": "Social Media" },
    { "type": "text", "id": "social_label", "label": "Label", "default": "Follow Us On" },
    { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "url", "id": "social_twitter", "label": "Twitter / X URL" },
    { "type": "url", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "url", "id": "social_linkedin", "label": "LinkedIn URL" },
    { "type": "header", "content": "Bottom Bar" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "info": "Leave blank to auto-generate." },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
