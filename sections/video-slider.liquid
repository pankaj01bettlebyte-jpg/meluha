{{ 'video-slider.css' | asset_url | stylesheet_tag }}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sliderEl = document.querySelector('.videoSwiper');
    if (!sliderEl || typeof Swiper === 'undefined') return;

    const totalSlides = sliderEl.querySelectorAll('.swiper-slide').length;

    const swiper = new Swiper('.videoSwiper', {
      slidesPerView: 2.2,
      spaceBetween: 20,
      centeredSlides: false,

      autoplay: {
        delay: 0, // 🔥 key trick
        disableOnInteraction: false,
      },

      speed: 4000, // 🔥 smooth continuous motion
      loop: true,
      freeMode: true,
      freeModeMomentum: false,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },

      breakpoints: {
        768: { slidesPerView: 2 },
        1024: { slidesPerView: 2.5 },
      },
    });

    sliderEl.addEventListener('click', function (e) {
      const btn = e.target.closest('.play-btn');
      if (!btn) return;

      const card = btn.closest('.video-card');
      const url = btn.dataset.video;

      if (!url || !card || card.classList.contains('video-loaded')) return;

      card.classList.add('video-loaded');

      let embedUrl = url;

      if (url.includes('youtube.com/watch')) {
        const videoId = new URL(url).searchParams.get('v');
        embedUrl = `https://www.youtube.com/embed/${videoId}`;
      }

      const iframe = document.createElement('iframe');
      iframe.src = `${embedUrl}?autoplay=1&mute=1`;
      iframe.allow = 'autoplay; encrypted-media';
      iframe.allowFullscreen = true;

      iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;';

      card.style.position = 'relative';
      card.querySelector('img').style.display = 'none';
      btn.style.display = 'none';

      card.appendChild(iframe);
    });
  });
</script>

<div class="video-slider">
  <div class="swiper videoSwiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide">
          <div class="video-card">
            <img
              src="{{ block.settings.thumbnail | image_url: width: 600 }}"
              alt="video"
              width=""
              height=""
            >

            <button class="play-btn" data-video="{{ block.settings.video_url }}">▶</button>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="swiper-pagination"></div>
  </div>
</div>

{% schema %}
{
  "name": "Video Slider",
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (YouTube or MP4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Slider"
    }
  ]
}
{% endschema %}
