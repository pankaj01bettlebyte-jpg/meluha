{{ 'video-slider.css' | asset_url | stylesheet_tag }}

<script>
  function initVideoSwiper() {
    const sliderEl = document.querySelector('.videoSwiper');
    if (!sliderEl || typeof Swiper === 'undefined') return;

    // Prevent re-init (Shopify fix)
    if (sliderEl.classList.contains('swiper-initialized')) return;

    new Swiper(sliderEl, {
      slidesPerView: 1.1, // ✅ mobile first
      spaceBetween: 12,
      centeredSlides: false,
      loop: true,

      autoplay: {
        delay: 2500, // ❌ remove 0
        disableOnInteraction: false,
      },

      speed: 800, // ❌ reduce from 4000

      pagination: {
        el: sliderEl.querySelector('.swiper-pagination'),
        clickable: true,
      },

      breakpoints: {
        480: {
          slidesPerView: 1.3,
          spaceBetween: 12,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 15,
        },
        1024: {
          slidesPerView: 2.5,
          spaceBetween: 20,
        },
        1400: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
      },
    });
  }

  // Init
  document.addEventListener('DOMContentLoaded', initVideoSwiper);
  document.addEventListener('shopify:section:load', initVideoSwiper);
</script>

<div class="video-slider">
  <div class="swiper videoSwiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide">
          <div class="video-card">
            <img
              src="{{ block.settings.thumbnail | image_url: width: 600 }}"
              alt="video"
              width=""
              height=""
            >

            <button class="play-btn" data-video="{{ block.settings.video_url }}">▶</button>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="swiper-pagination"></div>
  </div>
</div>

{% schema %}
{
  "name": "Video Slider",
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (YouTube or MP4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Slider"
    }
  ]
}
{% endschema %}
