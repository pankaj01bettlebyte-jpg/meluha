{% comment %}
  Feature Slider - Infinite Scroll (No Gap, Production Ready)
{% endcomment %}

{{ 'feature-slider.css' | asset_url | stylesheet_tag }}

<style>
  .feature-track {
    --speed: {{ section.settings.speed }}s;
  }
</style>

<div class="feature-slider">
  {% if section.blocks.size > 0 %}
    <div class="feature-track">
      <!-- First Group -->
      <div class="feature-group">
        {% for block in section.blocks %}
          <div class="feature-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 60 }}"
                alt="{{ block.settings.text | escape }}"
                loading="lazy"
                width=""
                height=""
              >
            {% endif %}
            <span>{{ block.settings.text }}</span>
          </div>
        {% endfor %}
      </div>

      <!-- Duplicate Group (for seamless loop) -->
      <div class="feature-group">
        {% for block in section.blocks %}
          <div class="feature-item">
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 60 }}"
                alt="{{ block.settings.text | escape }}"
                loading="lazy"
                width=""
                height=""
              >
            {% endif %}
            <span>{{ block.settings.text }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <p style="text-align:center; padding:10px;">Add features from theme editor</p>
  {% endif %}
</div>

{% if section.blocks.size < 2 %}
  <style>
    .feature-track {
      animation: none;
      justify-content: center;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Feature Slider",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Rich in Protein"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Slider"
    }
  ]
}
{% endschema %}
