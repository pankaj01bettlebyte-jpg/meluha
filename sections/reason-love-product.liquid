{{ 'reason-love-product.css' | asset_url | stylesheet_tag }}

{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign product_image = section.settings.product_image
%}

<section class="reason-product">
  <div class="page-width">
    {% if heading != blank %}
      <h2 class="reason-product__heading">{{ heading }}</h2>
    {% endif %}

    <div class="reason-product__grid">
      <!-- LEFT COLUMN -->
      <div class="reason-product__col reason-product__col--left">
        {% for block in section.blocks %}
          {% if block.type == 'feature' and block.settings.position == 'left' %}
            <div class="feature" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <img
                  src="{{ block.settings.icon | image_url: width: 80 }}"
                  alt="icon"
                  class="feature__icon-img"
                  loading="lazy"
                  width=""
                  height=""
                >
              {% else %}
                <div class="feature__icon"></div>
              {% endif %}

              <p class="feature__text">
                {{ block.settings.text }}
              </p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- CENTER -->
      <div class="reason-product__center">
        <div class="product-circle">
          {% if product_image != blank %}
            <img
              src="{{ product_image | image_url: width: 600 }}"
              alt="{{ product_image.alt | escape }}"
              loading="lazy"
              width="480"
              height="480"
            >
          {% else %}
            <div class="placeholder">Add Image</div>
          {% endif %}
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="reason-product__col reason-product__col--right">
        {% for block in section.blocks %}
          {% if block.type == 'feature' and block.settings.position == 'right' %}
            <div class="feature" {{ block.shopify_attributes }}>
              <p class="feature__text">
                {{ block.settings.text }}
              </p>

              {% if block.settings.icon != blank %}
                <img
                  src="{{ block.settings.icon | image_url: width: 80 }}"
                  alt="icon"
                  class="feature__icon-img"
                  loading="lazy"
                  width=""
                  height=""
                >
              {% else %}
                <div class="feature__icon"></div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if description != blank %}
      <p class="reason-product__desc">{{ description }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Reason Love Product",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reason you’ll love our Product"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Bottom Description"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Center Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Lorem ipsum is simply dummy text"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Reason Love Product",
      "blocks": [
        { "type": "feature", "settings": { "position": "left" } },
        { "type": "feature", "settings": { "position": "left" } },
        { "type": "feature", "settings": { "position": "left" } },
        { "type": "feature", "settings": { "position": "right" } },
        { "type": "feature", "settings": { "position": "right" } },
        { "type": "feature", "settings": { "position": "right" } }
      ]
    }
  ]
}
{% endschema %}
