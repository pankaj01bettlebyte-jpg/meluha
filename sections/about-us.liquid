<section class="about-us">
  <div class="page-width">
    <!-- STORY -->
    <div class="about-story">
      <h2>{{ section.settings.story_heading }}</h2>
      <p>{{ section.settings.story_text }}</p>
    </div>

    <!-- STATS -->
    <div class="about-stats">
      {% for block in section.blocks %}
        <div class="stat">
          <h3>{{ block.settings.number }}</h3>
          <p>{{ block.settings.label }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .about-us {
    padding: 10px 20px;
  }
  .about-story {
    margin-top: 10px;
    text-align: center;
  }

  .about-story h2 {
    font-size: 30px;
    margin-bottom: 20px;
  }

  .about-story p {
    max-width: 700px;
    margin: 0 auto;
    color: #555;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin: 60px 0;
    text-align: center;
  }

  .stat h3 {
    font-size: 28px;
    font-weight: bold;
  }

  .stat p {
    color: #777;
  }

  .about-mission {
    text-align: center;
  }

  .about-mission h2 {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .about-mission p {
    max-width: 700px;
    margin: 0 auto;
    color: #555;
  }

  /* RESPONSIVE */
  @media screen and (max-width: 768px) {
    .about-hero {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-hero__content h1 {
      font-size: 28px;
    }

    .about-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story Heading",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "Story Text",
      "default": "Write your brand story here..."
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission Heading",
      "default": "Our Mission"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text",
      "default": "Explain your mission clearly."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stats",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "10K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy Customers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}
