{% comment %}
  Meluha Foods — Contact Us Page
  File: templates/page.contact.liquid
  OR:   templates/contact.liquid  (if using as standalone)

  HOW MESSAGES REACH YOUR EMAIL:
  - Uses Shopify's native {% form 'contact' %} tag
  - Shopify automatically emails ALL submissions to your store's
    notification email (Admin → Settings → Notifications → Sender email)
  - Zero third-party apps needed.

  SETUP:
  1. Place this file at: templates/page.contact.liquid
  2. In Shopify Admin → Pages → Create page titled "Contact Us"
  3. Under Template, select "page.contact"
  4. Save — done. Messages go straight to your store email.
{% endcomment %}

{%- liquid
  assign store_email = shop.email
  assign store_phone = shop.phone
  assign store_address = shop.address
-%}

<div class="contact-page">
  {%- comment -%} ── Decorative background ────────────────────────────────── {%- endcomment -%}
  <div class="contact-bg" aria-hidden="true">
    <div class="contact-bg__shape contact-bg__shape--1"></div>
    <div class="contact-bg__shape contact-bg__shape--2"></div>
    <div class="contact-bg__dots"></div>
  </div>

  {%- comment -%} ── Hero ─────────────────────────────────────────────────── {%- endcomment -%}
  <div class="contact-hero">
    <div class="contact-hero__inner">
      <p class="contact-hero__eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        We'd love to hear from you
      </p>
      <h1 class="contact-hero__title">Contact Us</h1>
      <p class="contact-hero__desc">
        Have a question, feedback, or just want to say hello? Fill in the form and we'll get back to you within 24
        hours.
      </p>
    </div>
    <div class="contact-hero__deco" aria-hidden="true">
      <span class="contact-hero__circle contact-hero__circle--1"></span>
      <span class="contact-hero__circle contact-hero__circle--2"></span>
    </div>
  </div>

  {%- comment -%} ── Main layout ──────────────────────────────────────────── {%- endcomment -%}
  <div class="contact-layout">
    {%- comment -%} ══ LEFT — Store Information ══════════════════════════════ {%- endcomment -%}
    <aside class="contact-info">
      <div class="contact-info__card">
        <h2 class="contact-info__heading">Store Information</h2>

        <ul class="contact-info__list" role="list">
          {%- comment -%} Email {%- endcomment -%}
          {%- if store_email != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon contact-info__icon--email" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <div class="contact-info__detail">
                <span class="contact-info__label">Email</span>
                <a href="mailto:{{ store_email }}" class="contact-info__value contact-info__value--link">
                  {{- store_email -}}
                </a>
              </div>
            </li>
          {%- else -%}
            <li class="contact-info__item">
              <span class="contact-info__icon contact-info__icon--email" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <div class="contact-info__detail">
                <span class="contact-info__label">Email</span>
                <a href="mailto:demo@meluha.com" class="contact-info__value contact-info__value--link"
                  >demo@meluha.com</a
                >
              </div>
            </li>
          {%- endif -%}

          {%- comment -%} Phone {%- endcomment -%}
          {%- if store_phone != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon contact-info__icon--phone" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.02l-2.2 2.2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <div class="contact-info__detail">
                <span class="contact-info__label">Phone</span>
                <a href="tel:{{ store_phone | remove: ' ' }}" class="contact-info__value contact-info__value--link">
                  {{- store_phone -}}
                </a>
              </div>
            </li>
          {%- endif -%}

          {%- comment -%} Address {%- endcomment -%}
          {%- if store_address != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon contact-info__icon--address" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </span>
              <div class="contact-info__detail">
                <span class="contact-info__label">Address</span>
                <address class="contact-info__value contact-info__value--address">
                  {{ store_address.address1 -}}
                  {%- if store_address.address2 != blank -%}
                    <br>
                    {{ store_address.address2 -}}
                  {%- endif -%}
                  <br>
                  {{ store_address.city -}}
                  {%- if store_address.province != blank %}, {{ store_address.province }}{% endif -%}
                  <br>
                  {{ store_address.country }}
                </address>
              </div>
            </li>
          {%- else -%}
            <li class="contact-info__item">
              <span class="contact-info__icon contact-info__icon--address" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </span>
              <div class="contact-info__detail">
                <span class="contact-info__label">Address</span>
                <address class="contact-info__value contact-info__value--address">
                  Dummy address<br>
                  Dummy address<br>
                  Dummy address
                </address>
              </div>
            </li>
          {%- endif -%}

          {%- comment -%} Business hours {%- endcomment -%}
          <li class="contact-info__item">
            <span class="contact-info__icon contact-info__icon--hours" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="contact-info__detail">
              <span class="contact-info__label">Business Hours</span>
              <span class="contact-info__value">Mon – Sat: 9am – 6pm IST</span>
            </div>
          </li>
        </ul>

        {%- comment -%} Social row {%- endcomment -%}
        <div class="contact-info__social">
          <p class="contact-info__social-label">Follow us</p>
          <div class="contact-info__social-row">
            {%- if settings.social_instagram_link != blank -%}
              <a
                href="{{ settings.social_instagram_link }}"
                class="cinfo-social cinfo-social--ig"
                target="_blank"
                rel="noopener"
                aria-label="Instagram"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="2" width="20" height="20" rx="5.5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <a
                href="{{ settings.social_facebook_link }}"
                class="cinfo-social cinfo-social--fb"
                target="_blank"
                rel="noopener"
                aria-label="Facebook"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a
                href="{{ settings.social_twitter_link }}"
                class="cinfo-social cinfo-social--tw"
                target="_blank"
                rel="noopener"
                aria-label="Twitter"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- comment -%} Fallback: always show at least WhatsApp if no settings {%- endcomment -%}
            {%- if settings.social_instagram_link == blank
              and settings.social_facebook_link == blank
              and settings.social_twitter_link == blank
            -%}
              <span class="contact-info__social-empty">Set social links in Theme Editor → Settings</span>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} Response time badge {%- endcomment -%}
      <div class="contact-info__badge">
        <span class="contact-info__badge-dot" aria-hidden="true"></span>
        We typically respond within 24 hours
      </div>
    </aside>

    {%- comment -%} ══ RIGHT — Contact Form ══════════════════════════════════ {%- endcomment -%}
    <div class="contact-form-wrap">
      {%- comment -%}
        Shopify's native contact form tag.
        On submit → Shopify sends the message to your store notification email automatically.
        No app, no webhook, no third-party needed.
      {%- endcomment -%}
      {%- form 'contact', id: 'contact-form', class: 'contact-form' -%}
        <h2 class="contact-form__heading">Contact Us</h2>

        {%- comment -%} Success state ──────────────────────────────────────── {%- endcomment -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-form__success" role="alert" aria-live="polite">
            <div class="contact-form__success-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#0d6b3a"/><path d="M7 12l4 4 6-6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="contact-form__success-title">Message sent successfully!</p>
              <p class="contact-form__success-desc">
                Thank you for reaching out. We'll get back to you within 24 hours.
              </p>
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Error state ────────────────────────────────────────── {%- endcomment -%}
        {%- if form.errors -%}
          <div class="contact-form__error" role="alert" aria-live="assertive">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
            <div>
              {%- for field in form.errors -%}
                <p>{{ form.errors.translated_fields[field] | capitalize }}: {{ form.errors.messages[field] }}</p>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Row 1 — Name + Email ─────────────────────────────── {%- endcomment -%}
        <div class="contact-form__row contact-form__row--2col">
          <div class="contact-form__field">
            <label for="contact-name" class="contact-form__label">
              Name <span class="contact-form__required" aria-label="required">*</span>
            </label>
            <div class="contact-form__input-wrap">
              <svg
                class="contact-form__input-icon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.7"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              </svg>
              <input
                id="contact-name"
                type="text"
                name="contact[name]"
                class="contact-form__input"
                placeholder="Your full name"
                required
                aria-required="true"
                autocomplete="name"
                value="{{ form.name }}"
              >
            </div>
          </div>

          <div class="contact-form__field">
            <label for="contact-email" class="contact-form__label">
              Email Address <span class="contact-form__required" aria-label="required">*</span>
            </label>
            <div class="contact-form__input-wrap">
              <svg
                class="contact-form__input-icon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              </svg>
              <input
                id="contact-email"
                type="email"
                name="contact[email]"
                class="contact-form__input"
                placeholder="abc.123@gmail.com"
                required
                aria-required="true"
                autocomplete="email"
                value="{{ form.email }}"
              >
            </div>
          </div>
        </div>

        {%- comment -%} Row 2 — Phone + Subject ──────────────────────────── {%- endcomment -%}
        <div class="contact-form__row contact-form__row--2col">
          <div class="contact-form__field">
            <label for="contact-phone" class="contact-form__label"
              >Phone Number <span class="contact-form__optional">(Optional)</span></label
            >
            <div class="contact-form__input-wrap">
              <svg
                class="contact-form__input-icon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.02l-2.2 2.2z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <input
                id="contact-phone"
                type="tel"
                name="contact[phone]"
                class="contact-form__input"
                placeholder="+91 98765 43210"
                autocomplete="tel"
                value="{{ form.phone }}"
              >
            </div>
          </div>

          <div class="contact-form__field">
            <label for="contact-subject" class="contact-form__label">
              Subject <span class="contact-form__required" aria-label="required">*</span>
            </label>
            <div class="contact-form__input-wrap contact-form__input-wrap--select">
              <svg
                class="contact-form__input-icon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              </svg>
              <select
                id="contact-subject"
                name="contact[subject]"
                class="contact-form__input contact-form__input--select"
                required
                aria-required="true"
              >
                <option value="" disabled selected>Select a subject</option>
                <option value="Customer service">Customer service</option>
                <option value="Order inquiry">Order inquiry</option>
                <option value="Product information">Product information</option>
                <option value="Return or refund">Return or refund</option>
                <option value="Wholesale / Bulk order">Wholesale / Bulk order</option>
                <option value="Feedback">Feedback</option>
                <option value="Partnership">Partnership</option>
                <option value="Other">Other</option>
              </select>
              <svg
                class="contact-form__select-chevron"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        {%- comment -%} Row 3 — Attachment ───────────────────────────────── {%- endcomment -%}
        <div class="contact-form__field">
          <label for="contact-attachment" class="contact-form__label">
            Attachment
            <span class="contact-form__optional">(Optional)</span>
            <span class="contact-form__hint">PNG, JPG, PDF up to 5MB</span>
          </label>
          <div class="contact-form__file-row">
            <input
              id="contact-attachment"
              type="file"
              name="contact[attachment]"
              class="contact-form__file-input"
              accept=".png,.jpg,.jpeg,.pdf,.webp"
              aria-describedby="contact-attachment-hint"
            >
            <label for="contact-attachment" class="contact-form__file-btn" tabindex="0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Choose File
            </label>
            <span class="contact-form__file-name" id="contact-file-name">No file chosen</span>
            <span id="contact-attachment-hint" class="sr-only">PNG, JPG or PDF, max 5MB</span>
          </div>
        </div>

        {%- comment -%} Row 4 — Message ─────────────────────────────────── {%- endcomment -%}
        <div class="contact-form__field">
          <label for="contact-message" class="contact-form__label">
            Message <span class="contact-form__required" aria-label="required">*</span>
          </label>
          <div class="contact-form__input-wrap contact-form__input-wrap--textarea">
            <svg
              class="contact-form__input-icon contact-form__input-icon--top"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <textarea
              id="contact-message"
              name="contact[body]"
              class="contact-form__textarea"
              placeholder="How can we help?"
              rows="5"
              required
              aria-required="true"
              maxlength="2000"
              data-char-count
            >{{ form.body }}</textarea>
          </div>
          <div class="contact-form__char-count"><span id="contact-char-remaining">2000</span> characters remaining</div>
        </div>

        {%- comment -%} Submit ──────────────────────────────────────────── {%- endcomment -%}
        <div class="contact-form__submit-row">
          <p class="contact-form__privacy">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2L4 6v6c0 5.25 3.5 10.15 8 11.5C16.5 22.15 20 17.25 20 12V6l-8-4z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Your data is safe. We never share your information.
          </p>
          <button type="submit" class="contact-form__btn" id="contact-submit">
            <span class="contact-form__btn-text">Send Message</span>
            <span class="contact-form__btn-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="contact-form__btn-spinner" aria-hidden="true"></span>
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
  {%- comment -%} /.contact-layout {%- endcomment -%}

  {%- comment -%} ── Map / bottom strip (optional) ────────────────────────── {%- endcomment -%}
  <div class="contact-strip">
    <div class="contact-strip__inner">
      <div class="contact-strip__item">
        <div class="contact-strip__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.7"/><path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="contact-strip__label">Email us at</p>
          <a href="mailto:{{ store_email | default: 'demo@meluha.com' }}" class="contact-strip__value">
            {{- store_email | default: 'demo@meluha.com' -}}
          </a>
        </div>
      </div>
      <div class="contact-strip__divider" aria-hidden="true"></div>
      <div class="contact-strip__item">
        <div class="contact-strip__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="contact-strip__label">Response time</p>
          <p class="contact-strip__value">Within 24 hours</p>
        </div>
      </div>
      <div class="contact-strip__divider" aria-hidden="true"></div>
      <div class="contact-strip__item">
        <div class="contact-strip__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.7"/>
