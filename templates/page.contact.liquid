    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .contact-bg__shape {
    position: absolute;
    border-radius: 50%;
  }
  .contact-bg__shape--1 {
    width: 500px;
    height: 500px;
    background: rgba(13, 107, 58, 0.04);
    top: -150px;
    right: -120px;
  }
  .contact-bg__shape--2 {
    width: 300px;
    height: 300px;
    background: rgba(126, 207, 90, 0.06);
    bottom: 100px;
    left: -80px;
  }

  /* ══════════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════════ */
