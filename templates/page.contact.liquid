</div>

<style>
  :root {
    --ct-green: #0d6b3a;
    --ct-green-light: #e8f5ee;
    --ct-green-mid: #1a8a4a;
    --ct-accent: #7ecf5a;
    --ct-text: #1a2414;
    --ct-text-muted: #5a6b52;
    --ct-border: #d4e8ca;
    --ct-bg: #f6fbf4;
    --ct-white: #ffffff;
    --ct-error: #d94040;
    --ct-error-bg: #fff2f2;
    --ct-shadow: 0 4px 24px rgba(13, 107, 58, 0.09);
    --ct-radius: 14px;
    --ct-input-radius: 10px;
    --ct-pad-x: clamp(16px, 5vw, 64px);
    --ct-max-w: 1100px;
    --ct-transition: 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body: 'DM Sans', 'Nunito', system-ui, sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700;800&display=swap');

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-page {
    background: var(--ct-bg);
    font-family: var(--font-body);
    position: relative;
  }

  /* ── Background deco ── */
