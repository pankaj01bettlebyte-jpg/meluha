<script>
  (function () {
    'use strict';

    // ── File name display ──────────────────────────────────────────────────────
    var fileInput = document.getElementById('contact-attachment');
    var fileNameEl = document.getElementById('contact-file-name');

    if (fileInput && fileNameEl) {
      fileInput.addEventListener('change', function () {
        var file = fileInput.files[0];
        if (file) {
          // Validate size (5MB)
          if (file.size > 5 * 1024 * 1024) {
            fileNameEl.textContent = '⚠ File too large (max 5MB)';
            fileNameEl.style.color = '#d94040';
            fileInput.value = '';
            return;
          }
          fileNameEl.textContent = file.name;
          fileNameEl.style.color = '';
        } else {
          fileNameEl.textContent = 'No file chosen';
          fileNameEl.style.color = '';
        }
      });
    }

    // ── Character counter ──────────────────────────────────────────────────────
    var textarea = document.querySelector('[data-char-count]');
    var charRemain = document.getElementById('contact-char-remaining');
    var maxLen = 2000;

    if (textarea && charRemain) {
      function updateCount() {
        var remaining = maxLen - textarea.value.length;
        charRemain.textContent = remaining;
        charRemain.style.color = remaining < 100 ? '#d94040' : '';
      }
      textarea.addEventListener('input', updateCount);
      updateCount();
    }

    // ── Submit loading state ───────────────────────────────────────────────────
    var form = document.getElementById('contact-form');
    var submitBtn = document.getElementById('contact-submit');

    if (form && submitBtn) {
      form.addEventListener('submit', function () {
        // Basic HTML5 validation check
        if (!form.checkValidity()) return;
        submitBtn.classList.add('is-loading');
        submitBtn.disabled = true;
        // Safety reset after 10s in case of network error
        setTimeout(function () {
          submitBtn.classList.remove('is-loading');
          submitBtn.disabled = false;
        }, 10000);
      });
    }

    // ── Input validation feedback ──────────────────────────────────────────────
    var inputs = document.querySelectorAll('.contact-form__input, .contact-form__textarea');

    inputs.forEach(function (input) {
      input.addEventListener('blur', function () {
        var wrap = input.closest('.contact-form__input-wrap') || input.parentElement;
        if (input.required && !input.value.trim()) {
          input.style.borderColor = '#d94040';
          input.style.boxShadow = '0 0 0 3px rgba(217,64,64,0.1)';
        } else if (input.type === 'email' && input.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
          input.style.borderColor = '#d94040';
          input.style.boxShadow = '0 0 0 3px rgba(217,64,64,0.1)';
        } else {
          input.style.borderColor = '';
          input.style.boxShadow = '';
        }
      });

      input.addEventListener('focus', function () {
        input.style.borderColor = '';
        input.style.boxShadow = '';
      });
    });
  })();
</script>
