{% comment %}
  Meluha Foods — Policy Page Template
  Covers: Privacy Policy, Terms of Service, Refund Policy, Shipping Policy, etc.
  Usage: Place in templates/policy.liquid
  Content comes from Shopify's built-in {{ policy }} object — no manual editing needed.
{% endcomment %}

<div class="policy-page">
  {%- comment -%} ── Hero banner ─────────────────────────────────────────── {%- endcomment -%}
  <div class="policy-hero">
    <div class="policy-hero__inner">
      {%- comment -%} Breadcrumb {%- endcomment -%}
      <nav class="policy-hero__breadcrumb" aria-label="Breadcrumb">
        <ol role="list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </li>
          <li aria-current="page">{{ policy.title }}</li>
        </ol>
      </nav>

      <h1 class="policy-hero__title">{{ policy.title }}</h1>

      {%- comment -%} Last updated badge {%- endcomment -%}
      <div class="policy-hero__meta">
        <span class="policy-hero__badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          </svg>
          Last updated: {{ 'now' | date: '%B %d, %Y' }}
        </span>
        <span class="policy-hero__badge policy-hero__badge--secure">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2L4 6v6c0 5.25 3.5 10.15 8 11.5C16.5 22.15 20 17.25 20 12V6l-8-4z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Secure & Confidential
        </span>
      </div>
    </div>

    {%- comment -%} Decorative circles ─────────────────────────────────── {%- endcomment -%}
    <div class="policy-hero__deco" aria-hidden="true">
      <span class="policy-hero__circle policy-hero__circle--1"></span>
      <span class="policy-hero__circle policy-hero__circle--2"></span>
      <span class="policy-hero__circle policy-hero__circle--3"></span>
    </div>
  </div>

  {%- comment -%} ── Main layout: TOC sidebar + content ──────────────────── {%- endcomment -%}
  <div class="policy-layout">
    {%- comment -%} Sticky sidebar TOC (JS-generated from h2/h3 headings) ── {%- endcomment -%}
    <aside class="policy-toc" aria-label="Table of contents">
      <div class="policy-toc__inner" id="policy-toc">
        <p class="policy-toc__label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 12h10M4 18h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          Contents
        </p>
        <nav aria-label="Policy sections">
          <ul class="policy-toc__list" id="policy-toc-list" role="list"></ul>
        </nav>
      </div>
    </aside>

    {%- comment -%} Policy body ─────────────────────────────────────────── {%- endcomment -%}
    <article class="policy-content" id="policy-content">
      {{ policy.body }}
    </article>
  </div>

  {%- comment -%} ── Bottom CTA ──────────────────────────────────────────── {%- endcomment -%}
  <div class="policy-footer-cta">
    <div class="policy-footer-cta__inner">
      <p class="policy-footer-cta__text">Have questions about this policy?</p>
      <a href="/pages/contact" class="policy-footer-cta__btn">
        Contact Us
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  {%- comment -%} ── Other policies quick links ───────────────────────────── {%- endcomment -%}
  <div class="policy-related">
    <div class="policy-related__inner">
      <p class="policy-related__label">Other Policies</p>
      <ul class="policy-related__list" role="list">
        {%- if shop.privacy_policy.url != blank and policy.title != shop.privacy_policy.title -%}
          <li>
            <a href="{{ shop.privacy_policy.url }}" class="policy-related__link">{{ shop.privacy_policy.title }}</a>
          </li>
        {%- endif -%}
        {%- if shop.refund_policy.url != blank and policy.title != shop.refund_policy.title -%}
          <li>
            <a href="{{ shop.refund_policy.url }}" class="policy-related__link">{{ shop.refund_policy.title }}</a>
          </li>
        {%- endif -%}
        {%- if shop.terms_of_service.url != blank and policy.title != shop.terms_of_service.title -%}
          <li>
            <a href="{{ shop.terms_of_service.url }}" class="policy-related__link">{{ shop.terms_of_service.title }}</a>
          </li>
        {%- endif -%}
        {%- if shop.shipping_policy.url != blank and policy.title != shop.shipping_policy.title -%}
          <li>
            <a href="{{ shop.shipping_policy.url }}" class="policy-related__link">{{ shop.shipping_policy.title }}</a>
          </li>
        {%- endif -%}
        {%- if shop.subscription_policy.url != blank and policy.title != shop.subscription_policy.title -%}
          <li>
            <a href="{{ shop.subscription_policy.url }}" class="policy-related__link">
              {{- shop.subscription_policy.title -}}
            </a>
          </li>
        {%- endif -%}
      </ul>
    </div>
  </div>
</div>

<style>
  :root {
    --pol-green: #0d6b3a;
    --pol-green-light: #e8f5ee;
    --pol-green-mid: #1a8a4a;
    --pol-accent: #7ecf5a;
    --pol-text: #1e2d1a;
    --pol-text-muted: #6b7a62;
    --pol-border: #daecd0;
    --pol-bg: #f6fbf4;
    --pol-white: #ffffff;
    --pol-radius: 12px;
    --pol-pad-x: clamp(16px, 5vw, 64px);
    --pol-max-w: 1180px;
    --pol-transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --font-pol: 'DM Sans', 'Nunito', Georgia, serif;
    --font-pol-body: 'DM Sans', 'Nunito', system-ui, sans-serif;
  }

  /* ── Page wrapper ── */
  .policy-page {
    background: var(--pol-bg);
    min-height: 60vh;
    font-family: var(--font-pol-body);
  }

  /* ══════════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════════ */
  .policy-hero {
    background: var(--pol-green);
    position: relative;
    overflow: hidden;
    padding: 56px var(--pol-pad-x) 52px;
  }

  .policy-hero__inner {
    max-width: var(--pol-max-w);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Breadcrumb */
  .policy-hero__breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    font-size: 0.8125rem;
  }

  .policy-hero__breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color var(--pol-transition);
  }

  .policy-hero__breadcrumb a:hover {
    color: #fff;
  }

  .policy-hero__breadcrumb li[aria-current='page'] {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }

  .policy-hero__breadcrumb svg {
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  /* Title */
  .policy-hero__title {
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 20px;
    line-height: 1.15;
    letter-spacing: -0.5px;
    font-family: var(--font-pol);
  }

  /* Meta badges */
  .policy-hero__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .policy-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
  }

  .policy-hero__badge--secure {
    background: rgba(126, 207, 90, 0.2);
    border-color: rgba(126, 207, 90, 0.4);
  }

  /* Decorative circles */
  .policy-hero__deco {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .policy-hero__circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .policy-hero__circle--1 {
    width: 300px;
    height: 300px;
    top: -100px;
    right: -80px;
  }
  .policy-hero__circle--2 {
    width: 180px;
    height: 180px;
    bottom: -60px;
    right: 200px;
  }
  .policy-hero__circle--3 {
    width: 80px;
    height: 80px;
    top: 30px;
    right: 240px;
  }

  /* ══════════════════════════════════════════════════
     LAYOUT — sidebar TOC + content
  ══════════════════════════════════════════════════ */
  .policy-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 40px;
    max-width: var(--pol-max-w);
    margin: 0 auto;
    padding: 48px var(--pol-pad-x) 56px;
    align-items: start;
  }

  /* ══════════════════════════════════════════════════
     SIDEBAR TOC
  ══════════════════════════════════════════════════ */
  .policy-toc {
    position: sticky;
    top: 90px;
  }

  .policy-toc__inner {
    background: var(--pol-white);
    border: 1px solid var(--pol-border);
    border-radius: var(--pol-radius);
    padding: 20px 18px;
    box-shadow: 0 2px 12px rgba(13, 107, 58, 0.06);
  }

  .policy-toc__label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pol-green);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .policy-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .policy-toc__list a {
    display: block;
    padding: 6px 10px;
    font-size: 0.8375rem;
    color: var(--pol-text-muted);
    text-decoration: none;
    border-radius: 6px;
    border-left: 2px solid transparent;
    transition: color var(--pol-transition), background var(--pol-transition), border-color var(--pol-transition);
    line-height: 1.4;
  }

  .policy-toc__list a:hover,
  .policy-toc__list a.is-active {
    color: var(--pol-green);
    background: var(--pol-green-light);
    border-left-color: var(--pol-green);
  }

  .policy-toc__list .toc-h3 a {
    padding-left: 22px;
    font-size: 0.8rem;
  }

  /* ══════════════════════════════════════════════════
     POLICY CONTENT
  ══════════════════════════════════════════════════ */
  .policy-content {
    background: var(--pol-white);
    border: 1px solid var(--pol-border);
    border-radius: var(--pol-radius);
    padding: clamp(28px, 4vw, 52px);
    box-shadow: 0 2px 16px rgba(13, 107, 58, 0.05);
    min-width: 0;
  }

  /* Typography for policy body content */
  .policy-content h1,
  .policy-content h2,
  .policy-content h3,
  .policy-content h4 {
    font-family: var(--font-pol);
    font-weight: 700;
    color: var(--pol-text);
    line-height: 1.25;
    margin: 2em 0 0.6em;
  }

  .policy-content h1 {
    font-size: 1.75rem;
  }

  .policy-content h2 {
    font-size: 1.25rem;
    color: var(--pol-green);
    padding-top: 1.2em;
    border-top: 1px solid var(--pol-border);
    scroll-margin-top: 100px;
  }

  .policy-content h2:first-child {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .policy-content h3 {
    font-size: 1.05rem;
    color: var(--pol-text);
    scroll-margin-top: 100px;
  }

  .policy-content h4 {
    font-size: 0.9375rem;
  }

  .policy-content p {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--pol-text-muted);
    margin: 0 0 1.1em;
  }

  .policy-content p:last-child {
    margin-bottom: 0;
  }

  .policy-content a {
    color: var(--pol-green);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--pol-transition);
  }

  .policy-content a:hover {
    color: var(--pol-green-mid);
  }

  /* Lists */
  .policy-content ul,
  .policy-content ol {
    margin: 0 0 1.2em 1.2em;
    padding: 0;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--pol-text-muted);
  }

  .policy-content li {
    margin-bottom: 0.4em;
  }

  .policy-content ul li::marker {
    color: var(--pol-accent);
  }
  .policy-content ol li::marker {
    color: var(--pol-green);
    font-weight: 700;
  }

  /* Strong */
  .policy-content strong {
    color: var(--pol-text);
    font-weight: 600;
  }

  /* Blockquote */
  .policy-content blockquote {
    margin: 1.5em 0;
    padding: 16px 20px;
    background: var(--pol-green-light);
    border-left: 4px solid var(--pol-green);
    border-radius: 0 var(--pol-radius) var(--pol-radius) 0;
    font-style: italic;
    color: var(--pol-text-muted);
  }

  /* Table */
  .policy-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.875rem;
    overflow-x: auto;
    display: block;
  }

  .policy-content th {
    background: var(--pol-green);
    color: #fff;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
  }

  .policy-content td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--pol-border);
    color: var(--pol-text-muted);
    vertical-align: top;
  }

  .policy-content tr:last-child td {
    border-bottom: none;
  }
  .policy-content tr:nth-child(even) td {
    background: var(--pol-green-light);
  }

  /* HR */
  .policy-content hr {
    border: none;
    border-top: 1px solid var(--pol-border);
    margin: 2em 0;
  }

  /* ══════════════════════════════════════════════════
     BOTTOM CTA
  ══════════════════════════════════════════════════ */
  .policy-footer-cta {
    background: var(--pol-green);
    padding: 36px var(--pol-pad-x);
  }

  .policy-footer-cta__inner {
    max-width: var(--pol-max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .policy-footer-cta__text {
    font-size: 1.0625rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .policy-footer-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: #fff;
    color: var(--pol-green);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 999px;
    transition: transform var(--pol-transition), box-shadow var(--pol-transition);
    white-space: nowrap;
  }

  .policy-footer-cta__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  /* ══════════════════════════════════════════════════
     RELATED POLICIES
  ══════════════════════════════════════════════════ */
  .policy-related {
    background: var(--pol-bg);
    padding: 28px var(--pol-pad-x) 48px;
    border-top: 1px solid var(--pol-border);
  }

  .policy-related__inner {
    max-width: var(--pol-max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .policy-related__label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pol-text-muted);
    margin: 0;
    flex-shrink: 0;
  }

  .policy-related__list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 10px;
    flex-wrap: wrap;
  }

  .policy-related__link {
    display: inline-block;
    padding: 6px 16px;
    background: var(--pol-white);
    border: 1px solid var(--pol-border);
    border-radius: 999px;
    font-size: 0.8375rem;
    color: var(--pol-green);
    text-decoration: none;
    font-weight: 500;
    transition: background var(--pol-transition), border-color var(--pol-transition), transform var(--pol-transition);
  }

  .policy-related__link:hover {
    background: var(--pol-green-light);
    border-color: var(--pol-green);
    transform: translateY(-1px);
  }

  /* ══════════════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════════════ */

  /* Tablet */
  @media (max-width: 900px) {
    .policy-layout {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-top: 36px;
    }

    .policy-toc {
      position: static;
      order: -1;
    }

    .policy-toc__inner {
      padding: 16px;
    }

    .policy-toc__list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }

    .policy-toc__list a {
      padding: 5px 12px;
      border-left: none;
      border: 1px solid var(--pol-border);
      border-radius: 999px;
      font-size: 0.8rem;
      background: var(--pol-bg);
    }

    .policy-toc__list a:hover,
    .policy-toc__list a.is-active {
      background: var(--pol-green-light);
      border-color: var(--pol-green);
    }

    .policy-toc__list .toc-h3 {
      display: none;
    } /* hide h3 on tablet to keep it clean */
  }

  /* Mobile */
  @media (max-width: 600px) {
    .policy-hero {
      padding: 36px var(--pol-pad-x) 32px;
    }
    .policy-hero__title {
      font-size: 1.6rem;
    }
    .policy-content {
      padding: 24px 18px;
    }
    .policy-content h2 {
      font-size: 1.1rem;
    }
    .policy-footer-cta__inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .policy-related__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  /* Focus */
  :focus-visible {
    outline: 2px solid var(--pol-green);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    var content = document.getElementById('policy-content');
    var tocList = document.getElementById('policy-toc-list');
    if (!content || !tocList) return;

    // ── Build TOC from h2 and h3 headings ─────────────────────────────────────
    var headings = content.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      var tocPanel = document.getElementById('policy-toc');
      if (tocPanel) tocPanel.style.display = 'none';
      return;
    }

    headings.forEach(function (heading, i) {
      // Give each heading an id if it doesn't have one
      if (!heading.id) {
        heading.id = 'policy-section-' + i;
      }

      var li = document.createElement('li');
      var tag = heading.tagName.toLowerCase();
      li.className = tag === 'h3' ? 'toc-h3' : '';

      var a = document.createElement('a');
      a.href = '#' + heading.id;
      a.textContent = heading.textContent.trim();

      // Smooth scroll
      a.addEventListener('click', function (e) {
        e.preventDefault();
        var target = document.getElementById(heading.id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', '#' + heading.id);
        }
      });

      li.appendChild(a);
      tocList.appendChild(li);
    });

    // ── Active TOC link on scroll ─────────────────────────────────────────────
    var tocLinks = tocList.querySelectorAll('a');

    function getActiveHeading() {
      var scrollY = window.scrollY + 120;
      var active = null;
      headings.forEach(function (h) {
        if (h.offsetTop <= scrollY) active = h;
      });
      return active;
    }

    function updateActiveToc() {
      var active = getActiveHeading();
      tocLinks.forEach(function (link) {
        link.classList.remove('is-active');
        if (active && link.getAttribute('href') === '#' + active.id) {
          link.classList.add('is-active');
        }
      });
    }

    var scrollTimer;
    window.addEventListener(
      'scroll',
      function () {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(updateActiveToc, 60);
      },
      { passive: true }
    );

    updateActiveToc();
  })();
</script>
