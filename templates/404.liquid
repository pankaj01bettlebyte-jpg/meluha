{% comment %}
  Meluha Foods — 404 Not Found Page
  File: templates/404.liquid
  Features: Animated illustration, search bar, quick links,
            featured collections, helpful CTAs. Fully responsive.
{% endcomment %}

<div class="e404-page">
  {%- comment -%} ── Animated background ──────────────────────────────────── {%- endcomment -%}
  <div class="e404-bg" aria-hidden="true">
    <div class="e404-bg__circle e404-bg__circle--1"></div>
    <div class="e404-bg__circle e404-bg__circle--2"></div>
    <div class="e404-bg__circle e404-bg__circle--3"></div>
    <div class="e404-bg__leaf e404-bg__leaf--1">
      <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M30 75C30 75 5 55 5 30C5 15 16 4 30 4C44 4 55 15 55 30C55 55 30 75 30 75Z" fill="currentColor"/>
        <path d="M30 75L30 20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="e404-bg__leaf e404-bg__leaf--2">
      <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M30 75C30 75 5 55 5 30C5 15 16 4 30 4C44 4 55 15 55 30C55 55 30 75 30 75Z" fill="currentColor"/>
        <path d="M30 75L30 20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="e404-bg__leaf e404-bg__leaf--3">
      <svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M30 75C30 75 5 55 5 30C5 15 16 4 30 4C44 4 55 15 55 30C55 55 30 75 30 75Z" fill="currentColor"/>
      </svg>
    </div>
  </div>

  {%- comment -%} ── Main content ─────────────────────────────────────────── {%- endcomment -%}
  <div class="e404-main">
    {%- comment -%} Big 404 illustration ─────────────────────────────────── {%- endcomment -%}
    <div class="e404-illustration" aria-hidden="true">
      <div class="e404-numbers">
        <span class="e404-num e404-num--4 e404-num--left">4</span>
        <div class="e404-icon">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            {%- comment -%} Plate / bowl {%- endcomment -%}
            <ellipse cx="60" cy="80" rx="46" ry="12" fill="rgba(13,107,58,0.12)"/>
            <ellipse cx="60" cy="72" rx="42" ry="10" fill="#e8f5ee" stroke="#0d6b3a" stroke-width="2"/>
            <ellipse cx="60" cy="72" rx="30" ry="6" fill="#c8e8c0"/>
            {%- comment -%} Makhana seeds scattered {%- endcomment -%}
            <circle cx="48" cy="70" r="5" fill="#f5f0e0" stroke="#c8a850" stroke-width="1.2"/>
            <circle cx="60" cy="67" r="5.5" fill="#f5f0e0" stroke="#c8a850" stroke-width="1.2"/>
            <circle cx="72" cy="70" r="5" fill="#f5f0e0" stroke="#c8a850" stroke-width="1.2"/>
            <circle cx="54" cy="74" r="4.5" fill="#f5f0e0" stroke="#c8a850" stroke-width="1.2"/>
            <circle cx="66" cy="74" r="4.5" fill="#f5f0e0" stroke="#c8a850" stroke-width="1.2"/>
            {%- comment -%} Question mark stem {%- endcomment -%}
            <path d="M60 15C60 15 75 22 75 35C75 46 65 50 60 55" stroke="#0d6b3a" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M60 55L60 60" stroke="#0d6b3a" stroke-width="4" stroke-linecap="round"/>
            <circle cx="60" cy="64" r="2.5" fill="#0d6b3a"/>
            {%- comment -%} Leaves on question mark {%- endcomment -%}
            <path d="M75 28C75 28 82 22 86 26C82 30 75 28 75 28Z" fill="#7ecf5a"/>
            <path d="M74 38C74 38 80 33 83 38C79 41 74 38 74 38Z" fill="#7ecf5a"/>
          </svg>
        </div>
        <span class="e404-num e404-num--4 e404-num--right">4</span>
      </div>
      {%- comment -%} Floating seeds animation {%- endcomment -%}
      <div class="e404-seeds">
        <span class="e404-seed e404-seed--1"></span>
        <span class="e404-seed e404-seed--2"></span>
        <span class="e404-seed e404-seed--3"></span>
        <span class="e404-seed e404-seed--4"></span>
        <span class="e404-seed e404-seed--5"></span>
      </div>
    </div>

    {%- comment -%} Text content ────────────────────────────────────────── {%- endcomment -%}
    <div class="e404-content">
      <p class="e404-eyebrow">Oops! Page not found</p>
      <h1 class="e404-title">Looks like this page has wandered off</h1>
      <p class="e404-desc">
        The page you're looking for may have been moved, deleted, or perhaps it never existed. Let's get you back on
        track.
      </p>

      {%- comment -%} Search bar ─────────────────────────────────────────── {%- endcomment -%}
      <form action="{{ routes.search_url }}" method="get" class="e404-search" role="search">
        <input type="hidden" name="type" value="product,article,page">
        <label for="e404-search-input" class="e404-search__label">Search our store</label>
        <div class="e404-search__row">
          <input
            id="e404-search-input"
            type="search"
            name="q"
            class="e404-search__input"
            placeholder="Search for products, recipes, pages…"
            autocomplete="off"
            aria-label="Search"
          >
          <button type="submit" class="e404-search__btn" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
              <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </form>

      {%- comment -%} CTA buttons ─────────────────────────────────────────── {%- endcomment -%}
      <div class="e404-ctas">
        <a href="{{ routes.root_url }}" class="e404-btn e404-btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 12L12 4l9 8M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to Home
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="e404-btn e404-btn--secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M1 1h3l1.68 8.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L21 5H5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="20" r="1.5" fill="currentColor"/><circle cx="18" cy="20" r="1.5" fill="currentColor"/>
          </svg>
          Shop All Products
        </a>
      </div>
    </div>
  </div>

  {%- comment -%} ── Quick links ──────────────────────────────────────────── {%- endcomment -%}
  <div class="e404-links">
    <div class="e404-links__inner">
      <p class="e404-links__label">Quick links</p>
      <ul class="e404-links__list" role="list">
        <li>
          <a href="{{ routes.root_url }}" class="e404-link">
            <span class="e404-link__icon">🏠</span>
            Home
          </a>
        </li>
        <li>
          <a href="{{ routes.all_products_collection_url }}" class="e404-link">
            <span class="e404-link__icon">🛍️</span>
            All Products
          </a>
        </li>
        {%- if shop.blogs.size > 0 -%}
          <li>
            <a href="/blogs/{{ shop.blogs.first.handle }}" class="e404-link">
              <span class="e404-link__icon">📖</span>
              Blog
            </a>
          </li>
        {%- endif -%}
        <li>
          <a href="/pages/contact" class="e404-link">
            <span class="e404-link__icon">✉️</span>
            Contact Us
          </a>
        </li>
        {%- if shop.customer_accounts_enabled -%}
          <li>
            {%- if customer -%}
              <a href="{{ routes.account_url }}" class="e404-link">
                <span class="e404-link__icon">👤</span>
                My Account
              </a>
            {%- else -%}
              <a href="{{ routes.account_login_url }}" class="e404-link">
                <span class="e404-link__icon">👤</span>
                Login
              </a>
            {%- endif -%}
          </li>
        {%- endif -%}
        <li>
          <a href="{{ routes.cart_url }}" class="e404-link">
            <span class="e404-link__icon">🛒</span>
            Cart
            {%- if cart.item_count > 0 -%}
              <span class="e404-link__count">({{ cart.item_count }})</span>
            {%- endif -%}
          </a>
        </li>
      </ul>
    </div>
  </div>

  {%- comment -%} ── Featured collections ─────────────────────────────────── {%- endcomment -%}
  {%- assign featured_collections = collections | where: 'published', true -%}
  {%- if collections.size > 0 -%}
    <div class="e404-collections">
      <div class="e404-collections__inner">
        <h2 class="e404-collections__heading">While you're here, explore our collections</h2>
        <div class="e404-collections__grid">
          {%- for col in collections limit: 4 -%}
            {%- unless col.handle == 'frontpage' or col.handle == 'all' -%}
              <a href="{{ col.url }}" class="e404-col-card">
                <div class="e404-col-card__img-wrap">
                  {%- if col.image != blank -%}
                    {{
                      col.image
                      | image_url: width: 400
                      | image_tag: loading: 'lazy', class: 'e404-col-card__img', alt: col.title
                    }}
                  {%- elsif col.products.first.featured_image != blank -%}
                    {{
                      col.products.first.featured_image
                      | image_url: width: 400
                      | image_tag: loading: 'lazy', class: 'e404-col-card__img', alt: col.title
                    }}
                  {%- else -%}
                    <div class="e404-col-card__img-ph" aria-hidden="true">
                      <svg width="36" height="36" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                    </div>
                  {%- endif -%}
                  <div class="e404-col-card__overlay"></div>
                </div>
                <div class="e404-col-card__body">
                  <span class="e404-col-card__title">{{ col.title }}</span>
                  <span class="e404-col-card__count">{{ col.products_count }} products</span>
                  <span class="e404-col-card__arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </a>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  :root {
    --e4-green: #0d6b3a;
    --e4-green-light: #e8f5ee;
    --e4-green-mid: #1a8a4a;
    --e4-accent: #7ecf5a;
    --e4-gold: #c8a850;
    --e4-text: #1a2414;
    --e4-text-muted: #5a6b52;
    --e4-border: #d8ead0;
    --e4-bg: #f4f8ee;
    --e4-white: #ffffff;
    --e4-shadow: 0 4px 24px rgba(13, 107, 58, 0.1);
    --e4-radius: 16px;
    --e4-pad-x: clamp(16px, 5vw, 64px);
    --e4-max-w: 1180px;
    --e4-transition: 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body: 'DM Sans', 'Nunito', system-ui, sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700;800&display=swap');

  /* ── Page wrapper ── */
  .e404-page {
    background: var(--e4-bg);
    font-family: var(--font-body);
    min-height: 80vh;
    position: relative;
    overflow-x: hidden;
  }

  /* ══════════════════════════════════════════════════
     ANIMATED BACKGROUND
  ══════════════════════════════════════════════════ */
  .e404-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .e404-bg__circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(13, 107, 58, 0.06);
  }
  .e404-bg__circle--1 {
    width: 500px;
    height: 500px;
    top: -180px;
    right: -120px;
    animation: e4float 8s ease-in-out infinite;
  }
  .e404-bg__circle--2 {
    width: 320px;
    height: 320px;
    bottom: 40px;
    left: -100px;
    animation: e4float 10s ease-in-out infinite reverse;
  }
  .e404-bg__circle--3 {
    width: 180px;
    height: 180px;
    top: 60%;
    right: 10%;
    animation: e4float 7s ease-in-out infinite 2s;
  }

  .e404-bg__leaf {
    position: absolute;
    color: rgba(126, 207, 90, 0.18);
    animation: e4spin 20s linear infinite;
  }
  .e404-bg__leaf--1 {
    width: 80px;
    height: 100px;
    top: 15%;
    left: 8%;
    animation-duration: 25s;
  }
  .e404-bg__leaf--2 {
    width: 50px;
    height: 66px;
    bottom: 25%;
    right: 12%;
    animation-duration: 18s;
    animation-direction: reverse;
  }
  .e404-bg__leaf--3 {
    width: 36px;
    height: 48px;
    top: 60%;
    left: 20%;
    animation-duration: 30s;
  }

  @keyframes e4float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes e4spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  /* ══════════════════════════════════════════════════
     MAIN CONTENT
  ══════════════════════════════════════════════════ */
  .e404-main {
    position: relative;
    z-index: 2;
    max-width: var(--e4-max-w);
    margin: 0 auto;
    padding: 64px var(--e4-pad-x) 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  /* ── 404 Illustration ── */
  .e404-illustration {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .e404-numbers {
    display: flex;
    align-items: center;
    gap: 8px;
    user-select: none;
  }

  .e404-num {
    font-family: var(--font-display);
    font-size: clamp(120px, 16vw, 180px);
    font-weight: 400;
    color: var(--e4-green);
    line-height: 1;
    letter-spacing: -4px;
    opacity: 0.12;
  }

  .e404-icon {
    width: clamp(100px, 14vw, 160px);
    height: clamp(100px, 14vw, 160px);
    flex-shrink: 0;
    animation: e4bounce 3s ease-in-out infinite;
  }

  .e404-icon svg {
    width: 100%;
    height: 100%;
  }

  @keyframes e4bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  /* Floating seeds */
  .e404-seeds {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .e404-seed {
    position: absolute;
    border-radius: 50%;
    background: #f5f0e0;
    border: 2px solid var(--e4-gold);
    animation: e4drift linear infinite;
  }

  .e404-seed--1 {
    width: 14px;
    height: 14px;
    left: 10%;
    top: 70%;
    animation-duration: 6s;
    animation-delay: 0s;
  }
  .e404-seed--2 {
    width: 10px;
    height: 10px;
    left: 80%;
    top: 60%;
    animation-duration: 8s;
    animation-delay: 1s;
  }
  .e404-seed--3 {
    width: 12px;
    height: 12px;
    left: 50%;
    top: 80%;
    animation-duration: 7s;
    animation-delay: 2s;
  }
  .e404-seed--4 {
    width: 8px;
    height: 8px;
    left: 25%;
    top: 50%;
    animation-duration: 9s;
    animation-delay: 0.5s;
  }
  .e404-seed--5 {
    width: 11px;
    height: 11px;
    left: 70%;
    top: 40%;
    animation-duration: 5.5s;
    animation-delay: 1.5s;
  }

  @keyframes e4drift {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0.8;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(-80px) rotate(360deg);
      opacity: 0;
    }
  }

  /* ── Text content ── */
  .e404-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .e404-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--e4-accent);
    margin: 0;
  }

  .e404-eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 2px;
    background: var(--e4-accent);
    border-radius: 2px;
  }

  .e404-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    font-weight: 400;
    color: var(--e4-text);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.3px;
  }

  .e404-desc {
    font-size: 1rem;
    line-height: 1.72;
    color: var(--e4-text-muted);
    margin: 0;
    max-width: 420px;
  }

  /* Search */
  .e404-search {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .e404-search__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--e4-text-muted);
  }

  .e404-search__row {
    display: flex;
    align-items: center;
    background: var(--e4-white);
    border: 2px solid var(--e4-border);
    border-radius: 999px;
    overflow: hidden;
    transition: border-color var(--e4-transition), box-shadow var(--e4-transition);
    max-width: 440px;
  }

  .e404-search__row:focus-within {
    border-color: var(--e4-green);
    box-shadow: 0 0 0 4px rgba(13, 107, 58, 0.12);
  }

  .e404-search__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    padding: 13px 20px;
    font-size: 0.9375rem;
    color: var(--e4-text);
    font-family: var(--font-body);
  }

  .e404-search__input::placeholder {
    color: rgba(90, 107, 82, 0.55);
  }

  .e404-search__btn {
    background: var(--e4-green);
    border: none;
    cursor: pointer;
    padding: 12px 20px;
    color: #fff;
    display: flex;
    align-items: center;
    transition: background var(--e4-transition);
    flex-shrink: 0;
  }

  .e404-search__btn:hover {
    background: var(--e4-green-mid);
  }

  /* CTAs */
  .e404-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .e404-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 24px;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    transition: all var(--e4-transition);
    white-space: nowrap;
  }

  .e404-btn--primary {
    background: var(--e4-green);
    color: #fff;
    border: 2px solid var(--e4-green);
  }

  .e404-btn--primary:hover {
    background: var(--e4-green-mid);
    border-color: var(--e4-green-mid);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13, 107, 58, 0.25);
  }

  .e404-btn--secondary {
    background: transparent;
    color: var(--e4-green);
    border: 2px solid var(--e4-border);
  }

  .e404-btn--secondary:hover {
    border-color: var(--e4-green);
    background: var(--e4-green-light);
    transform: translateY(-2px);
  }

  /* ══════════════════════════════════════════════════
     QUICK LINKS
  ══════════════════════════════════════════════════ */
  .e404-links {
    position: relative;
    z-index: 2;
    background: var(--e4-white);
    border-top: 1px solid var(--e4-border);
    border-bottom: 1px solid var(--e4-border);
    padding: 28px var(--e4-pad-x);
  }

  .e404-links__inner {
    max-width: var(--e4-max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .e404-links__label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--e4-text-muted);
    margin: 0;
    flex-shrink: 0;
  }

  .e404-links__list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 8px;
    flex-wrap: wrap;
  }

  .e404-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    background: var(--e4-bg);
    border: 1.5px solid var(--e4-border);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--e4-text-muted);
    text-decoration: none;
    transition: all var(--e4-transition);
  }

  .e404-link:hover {
    background: var(--e4-green-light);
    border-color: var(--e4-green);
    color: var(--e4-green);
    transform: translateY(-1px);
  }

  .e404-link__icon {
    font-size: 0.9rem;
    line-height: 1;
  }
  .e404-link__count {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--e4-green);
  }

  /* ══════════════════════════════════════════════════
     FEATURED COLLECTIONS
